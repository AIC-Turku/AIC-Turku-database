# 📝 Materials and Methods Generator

This tool generates a draft "Materials and Methods" text block aligned with the **QUAREP-LiMi minimal reporting requirements** for light microscopy ([Better reporting is better science](https://rupress.org/jcb/article/225/3/e202601032/281525/Better-reporting-is-better-science-Community)). Select a system, choose the specific hardware you used, and click **"Add to Methods"**. You can repeat this process for multiple microscopes and then complete any placeholders with experiment-specific metadata before publication.
<div class="aic-card" style="padding: 20px; margin-bottom: 20px; background-color: var(--md-default-bg-color);">
  <label for="system-select"><strong>1. Select Microscope:</strong></label>
  <select id="system-select" style="width: 100%; padding: 8px; margin-top: 5px; margin-bottom: 15px; border-radius: 4px; border: 1px solid var(--md-default-fg-color--light);">
    <option value="">-- Choose an instrument --</option>
  </select>

  <div id="methods-metadata-warning" class="admonition warning" style="display: none; margin-bottom: 15px;">
    <p class="admonition-title">Methods metadata blocker</p>
    <p style="margin: 0 0 8px 0;">This instrument is missing policy-critical metadata required for trustworthy method text generation.</p>
    <ul id="methods-metadata-blockers" style="margin: 0; padding-left: 20px;"></ul>
  </div>

  <div id="hardware-options" style="display: none;">
    <strong>2. Imaging Modalities:</strong>
    <div id="modality-list" style="margin-bottom: 15px; margin-top: 5px; margin-left: 10px;"></div>

    <strong>3. Hardware Modules &amp; Environmental Control:</strong>
    <div id="module-list" style="margin-bottom: 15px; margin-top: 5px; margin-left: 10px;"></div>

    <strong>4. Scanner:</strong>
    <div id="scanner-list" style="margin-bottom: 15px; margin-top: 5px; margin-left: 10px;"></div>

    <strong>5. Objectives:</strong>
    <div id="obj-list" style="margin-bottom: 15px; margin-top: 5px; margin-left: 10px;"></div>

    <strong>6. Light Sources (Lasers/LEDs):</strong>
    <div id="light-list" style="margin-bottom: 15px; margin-top: 5px; margin-left: 10px;"></div>

    <strong>7. Filters / Dichroics:</strong>
    <div id="filter-list" style="margin-bottom: 15px; margin-top: 5px; margin-left: 10px;"></div>

    <strong>8. Camera / Emission Splitters:</strong>
    <div id="splitter-list" style="margin-bottom: 15px; margin-top: 5px; margin-left: 10px;"></div>

    <strong>9. Detectors:</strong>
    <div id="det-list" style="margin-bottom: 15px; margin-top: 5px; margin-left: 10px;"></div>

    <button id="add-btn" class="md-button md-button--primary" style="margin-top: 10px;">+ Add to Methods</button>
  </div>
</div>

!!! tip "💡 Pro-Tip: Recover exact settings from raw metadata"
    Need exact exposure times, pixel sizes, and laser powers? Use your raw files (`.nd2`, `.czi`, `.lif`, etc.) and let Fiji/ImageJ + an LLM do the extraction for you:

    1. Open the raw image in **Fiji / ImageJ**.
    2. Press **`I`** (or use `Image > Show Info...`) to open complete acquisition metadata.
    3. Copy the metadata text and paste it into an LLM (e.g., ChatGPT/Copilot) with a prompt such as:
       *"Extract exact exposure times, pixel size (xy), z-step, pinhole size, and laser powers from this metadata."*

### Generated Text
<div style="position: relative;">
  <textarea id="output-text" rows="16" style="width: 100%; padding: 15px; border-radius: 4px; border: 1px solid var(--md-default-fg-color--light); background-color: var(--md-code-bg-color); font-family: monospace; line-height: 1.5;" readonly>Please select an instrument and click "Add to Methods".</textarea>
  <div style="margin-top: 10px; display: flex; gap: 10px;">
      <button id="copy-btn" class="md-button md-button--primary">Copy to Clipboard</button>
      <button id="clear-btn" class="md-button">Clear All</button>
      <span id="copy-feedback" style="color: green; margin-top: 8px; display: none;">Copied!</span>
  </div>
</div>

<script>
let vocabularies = {};

document.addEventListener("DOMContentLoaded", async () => {
    const instrumentsResponse = await fetch("../assets/instruments_data.json");
    const instrumentsPayload = await instrumentsResponse.json();
    const instruments = Array.isArray(instrumentsPayload)
        ? instrumentsPayload
        : (instrumentsPayload?.instruments || []);
    vocabularies = instrumentsPayload?.vocabularies || {};

    const systemSelect = document.getElementById("system-select");
    const hwOptions = document.getElementById("hardware-options");
    const outputText = document.getElementById("output-text");
    const copyBtn = document.getElementById("copy-btn");
    const clearBtn = document.getElementById("clear-btn");
    const addBtn = document.getElementById("add-btn");

    let currentInst = null;
    let accumulatedMethods = [];
    let usedInstrumentNames = new Set();

    const methodsMetadataWarning = document.getElementById("methods-metadata-warning");
    const methodsMetadataBlockers = document.getElementById("methods-metadata-blockers");

    // Populate dropdown
    instruments.forEach(inst => {
        const opt = document.createElement("option");
        opt.value = inst.id;
        opt.textContent = inst.retired ? `${inst.display_name} (Retired)` : inst.display_name;
        systemSelect.appendChild(opt);
    });


    function formatBlockerLabel(blocker) {
        const title = (blocker?.title || blocker?.path || "Missing field").toString().trim();
        const role = (blocker?.role || "").toString().trim();
        if (role) return `${title} (${toTitleCase(role)} software)`;
        return title;
    }

    function getMethodsMetadataStatus(inst) {
        const metadata = inst?.methods_generation || {};
        const blockers = Array.isArray(metadata?.blockers)
            ? metadata.blockers.filter(item => item?.kind === "instrument_metadata")
            : [];

        return {
            isBlocked: Boolean(metadata?.is_blocked) && blockers.length > 0,
            blockers,
            softwareByRole: metadata?.software_by_role || {},
        };
    }

    function renderMethodsMetadataWarning(inst) {
        const status = getMethodsMetadataStatus(inst);
        methodsMetadataBlockers.innerHTML = "";

        if (!status.isBlocked) {
            methodsMetadataWarning.style.display = "none";
            return status;
        }

        status.blockers.forEach(blocker => {
            const item = document.createElement("li");
            item.textContent = formatBlockerLabel(blocker);
            methodsMetadataBlockers.appendChild(item);
        });

        methodsMetadataWarning.style.display = "block";
        return status;
    }

    systemSelect.addEventListener("change", (e) => {
        const instId = e.target.value;
        currentInst = instruments.find(i => i.id === instId);

        if (!currentInst) {
            hwOptions.style.display = "none";
            methodsMetadataWarning.style.display = "none";
            methodsMetadataBlockers.innerHTML = "";
            return;
        }

        hwOptions.style.display = "block";
        renderMethodsMetadataWarning(currentInst);

        const modalityItems = currentInst.processed_hardware?.modalities || currentInst.modalities || [];
        populateCheckboxes("modality-list", modalityItems,
            modality => getLabel("modalities", modality), "modality",
            modality => getDescription("modalities", modality));

        const moduleItems = currentInst.processed_hardware?.modules || currentInst.modules || [];
        populateCheckboxes("module-list", moduleItems,
            module => {
                const moduleId = module?.id || module?.name || module;
                const moduleLabel = formatVocabLabel(vocabularies.modules, moduleId);
                const moduleNotes = (module?.notes || "").toString().trim();
                return moduleNotes ? `${moduleLabel} (${moduleNotes})` : moduleLabel;
            }, "module");

        const scanner = currentInst?.processed_hardware?.scanner || currentInst?.hardware?.scanner || null;
        const scannerItems = scanner ? [scanner] : [];
        populateCheckboxes("scanner-list", scannerItems,
            scannerItem => {
                const scannerTypeRaw = scannerItem?.type || scannerItem?.id || "";
                const scannerLabel = formatVocabLabel(vocabularies.scanner_types, scannerTypeRaw);
                const scannerNotes = (scannerItem?.notes || "").toString().trim();
                return scannerNotes ? `${scannerLabel} (${scannerNotes})` : scannerLabel;
            }, "scanner");

        // Formatting to match JCB/QUAREP-LiMi guidelines
        populateCheckboxes("obj-list", currentInst.processed_hardware.objectives,
            obj => formatObjectiveLabel(obj), "obj");

        populateCheckboxes("light-list", currentInst.processed_hardware.light_sources,
            ls => formatLightSourceLabel(ls), "light");

        populateCheckboxes("filter-list", currentInst.processed_hardware.filters, f => {
            let type = [];
            if (f.excitation) type.push(`Ex: ${f.excitation}`);
            if (f.dichroic) type.push(`Di: ${f.dichroic}`);
            if (f.emission) type.push(`Em: ${f.emission}`);

            // Label it based on what it actually does (helps users pick the right parts)
            let label = f.name;
            if (type.length > 0) {
                label += ` (${type.join(', ')})`;
            }
            return label;
        }, "filter");

        populateCheckboxes("splitter-list", currentInst.processed_hardware.splitters,
            s => `${s.name} (${s.type})`, "splitter");

        populateCheckboxes("det-list", currentInst.processed_hardware.detectors,
            d => formatDetectorLabel(d), "det");
    });

    function populateCheckboxes(containerId, items, labelFormatter, prefix, subtextFormatter) {
        const container = document.getElementById(containerId);
        container.innerHTML = "";
        if (!items || items.length === 0) {
            container.innerHTML = "<span style='color: gray; font-size: 0.9em;'>No data available.</span>";
            return;
        }

        items.forEach((item, index) => {
            const wrapper = document.createElement("div");
            wrapper.style.marginBottom = "4px";

            const checkbox = document.createElement("input");
            checkbox.type = "checkbox";
            checkbox.id = `${prefix}-${index}`;
            checkbox.value = labelFormatter(item).replace(/\s+/g, ' ').trim();

            const label = document.createElement("label");
            label.htmlFor = `${prefix}-${index}`;
            label.textContent = " " + checkbox.value;

            wrapper.appendChild(checkbox);
            wrapper.appendChild(label);

            const subtext = subtextFormatter ? subtextFormatter(item) : "";
            if (subtext) {
                const subtextEl = document.createElement("div");
                subtextEl.textContent = subtext;
                subtextEl.style.fontSize = "0.8em";
                subtextEl.style.fontStyle = "italic";
                subtextEl.style.color = "gray";
                subtextEl.style.marginLeft = "24px";
                wrapper.appendChild(subtextEl);
            }

            container.appendChild(wrapper);
        });
    }

    function getLabel(vocabName, id) {
        if (vocabularies[vocabName] && vocabularies[vocabName][id]) {
            return vocabularies[vocabName][id].label;
        }
        return id.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
    }

    function getDescription(vocabName, id) {
        if (vocabularies[vocabName] && vocabularies[vocabName][id]) {
            return vocabularies[vocabName][id].description;
        }
        return "";
    }

    function getCheckedValues(prefix) {
        const checkboxes = document.querySelectorAll(`input[id^="${prefix}-"]:checked`);
        return Array.from(checkboxes).map(cb => cb.value);
    }

    function formatVocabLabel(vocabSection, value) {
        const id = (value?.id || value?.name || value || "").toString().trim();
        if (!id) return "Unknown";

        if (vocabSection) {
            if (Array.isArray(vocabSection)) {
                const match = vocabSection.find(item => item?.id === id);
                if (match?.label) return match.label;
            } else if (typeof vocabSection === "object") {
                const mapped = vocabSection[id];
                if (mapped?.label) return mapped.label;
                if (typeof mapped === "string") return mapped;
            }
        }

        return toTitleCase(id);
    }

    function toTitleCase(value) {
        return (value || "")
            .toString()
            .replace(/_/g, " ")
            .trim()
            .split(/\s+/)
            .map(word => word.charAt(0).toUpperCase() + word.slice(1).toLowerCase())
            .join(" ");
    }

    function formatHumanList(items) {
        if (!items || items.length === 0) return "";
        if (items.length === 1) return items[0];
        if (items.length === 2) return `${items[0]} and ${items[1]}`;
        return `${items.slice(0, -1).join(", ")}, and ${items[items.length - 1]}`;
    }

    function formatWavelength(rawWavelength) {
        const wavelength = (rawWavelength || "").toString().trim();
        if (!wavelength) return "";

        // Add "nm" only for plain numeric wavelengths (e.g., 405, 488, 561.5).
        if (/^\d+(\.\d+)?$/.test(wavelength)) {
            return `${wavelength} nm`;
        }

        // Keep bandpass-style values (e.g., 395/25) and descriptive entries unchanged.
        return wavelength;
    }

    function formatLightSourceLabel(lightSource) {
        const wavelength = formatWavelength(lightSource?.wavelength);
        const type = (lightSource?.type || "light source").toString().trim();

        const sourceParts = [
            (lightSource?.power || "").toString().trim(),
            [lightSource?.manufacturer, lightSource?.name]
                .map(part => (part || "").toString().trim())
                .filter(Boolean)
                .join(" ")
        ].filter(Boolean);

        const detailText = sourceParts.length > 0 ? ` (${sourceParts.join(", ")})` : "";
        const leadText = wavelength ? `${wavelength} ${type}` : type;
        return `${leadText}${detailText}`.replace(/\s+/g, " ").trim();
    }


    function formatScannerDetails(scannerData) {
        if (!scannerData || !scannerData.type || scannerData.type.toLowerCase() === "none") return "";
        const details = [];
        if (scannerData?.line_rate_hz) details.push(`line rate ${scannerData.line_rate_hz} Hz`);
        if (scannerData?.pinhole_um) details.push(`pinhole ${scannerData.pinhole_um} µm`);
        return details.length > 0 ? ` (${details.join(", ")})` : "";
    }

    function formatDetectorLabel(detector) {
        const label = `${detector?.model || "Unknown detector"} ${detector?.type || ""} (${detector?.manufacturer || "Unknown manufacturer"})`.replace(/\s+/g, " ").trim();
        const details = [];
        if (detector?.pixel_pitch_um) details.push(`${detector.pixel_pitch_um} µm pixel pitch`);
        if (detector?.sensor_format_px) details.push(`sensor ${detector.sensor_format_px} px`);
        if (detector?.binning) details.push(`binning ${detector.binning}`);
        if (detector?.bit_depth) details.push(`${detector.bit_depth}-bit`);
        return details.length > 0 ? `${label}; ${details.join(", ")}` : label;
    }

    function formatProcessingMetadata(inst) {
        const softwareByRole = inst?.methods_generation?.software_by_role || {};
        const analysisRole = softwareByRole.analysis || {};
        const deconvolutionRole = softwareByRole.deconvolution || {};
        const flimRole = softwareByRole.flim || {};
        const software = Array.isArray(inst?.software) ? inst.software : [];
        const moduleItems = inst?.processed_hardware?.modules || inst?.modules || [];
        const moduleText = moduleItems
            .map(module => (module?.id || module?.name || module || "").toString().trim())
            .filter(Boolean)
            .join(" ")
            .toLowerCase();

        const processingKeywords = ["airyscan", "thunder", "deconvolution", "sim", "reconstruction", "flim", "lifetime"];
        const matchedKeywords = processingKeywords.filter(keyword => moduleText.includes(keyword));

        const roleSoftware = [analysisRole, deconvolutionRole, flimRole]
            .filter(role => role?.name && role?.version)
            .map(role => `${role.name} (v${role.version})`);

        const softwareText = (roleSoftware.length > 0
            ? roleSoftware
            : software.map(s => `${s?.name || "Unknown software"}${s?.version ? ` (v${s.version})` : ""}`)
        ).join(", ");

        if (matchedKeywords.length === 0 && !softwareText) {
            return "[PLEASE SPECIFY: Deconvolution/reconstruction/lifetime-fitting pipeline, including software name and version]. ";
        }

        const processingMethods = matchedKeywords.length > 0 ? formatHumanList(matchedKeywords.map(toTitleCase)) : "processing";
        const softwareClause = softwareText || "[software/version not specified]";
        return `Post-acquisition processing included ${processingMethods}; software used: ${softwareClause}. `;
    }
    function formatObjectiveLabel(obj) {
        const metadata = [];
        if (obj?.manufacturer) metadata.push(obj.manufacturer);
        if (obj?.product_code) metadata.push(`product code: ${obj.product_code}`);

        const objectiveModel = (obj?.model || obj?.name || "").replace(/\s+/g, " ").trim();

        if (objectiveModel) {
            return metadata.length > 0
                ? `${objectiveModel} objective (${metadata.join(", ")})`
                : `${objectiveModel} objective`;
        }

        const fallbackParts = [];
        const magnification = obj?.magnification ? `${obj.magnification}x` : "";
        const na = obj?.na ? `/${obj.na}` : "";
        const magnificationPart = `${magnification}${na}`;
        if (magnificationPart) fallbackParts.push(magnificationPart);
        if (obj?.immersion) fallbackParts.push(obj.immersion);
        fallbackParts.push("objective");

        return metadata.length > 0
            ? `${fallbackParts.join(" ")} (${metadata.join(", ")})`
            : fallbackParts.join(" ");
    }

    addBtn.addEventListener("click", () => {
        if (!currentInst) return;

        const objs = getCheckedValues("obj");
        const modalities = getCheckedValues("modality");
        const modules = getCheckedValues("module");
        const scanners = getCheckedValues("scanner");
        const lights = getCheckedValues("light");
        const filters = getCheckedValues("filter");
        const splitters = getCheckedValues("splitter");
        const dets = getCheckedValues("det");

        const methodsMetadataStatus = getMethodsMetadataStatus(currentInst);
        if (methodsMetadataStatus.isBlocked) {
            renderMethodsMetadataWarning(currentInst);
            const blockedFields = methodsMetadataStatus.blockers.map(formatBlockerLabel);
            const blockerSummary = blockedFields.length > 0
                ? formatHumanList(blockedFields)
                : "policy-critical instrument metadata";
            const blockedMessage = `Methods text for ${currentInst.display_name} cannot be generated yet because required instrument metadata is missing: ${blockerSummary}. Please complete the instrument metadata policy fields before generating authoritative methods text.`;

            accumulatedMethods.push(blockedMessage);
            updateOutputText();
            return;
        }

        const softwareByRole = methodsMetadataStatus.softwareByRole || {};
        const acquisitionSoftware = softwareByRole.acquisition || {};

        let softName = "[MISSING ACQUISITION SOFTWARE NAME AND VERSION]";
        if (acquisitionSoftware.name && acquisitionSoftware.version) {
            softName = `${acquisitionSoftware.name} (v${acquisitionSoftware.version})`;
        }

        const stand = currentInst.stand_orientation && currentInst.stand_orientation !== 'other'
            ? currentInst.stand_orientation + " "
            : "";

        const fallbackModalities = (currentInst.processed_hardware?.modalities || currentInst.modalities || [])
            .map(m => formatVocabLabel(vocabularies.modalities, m));
        const selectedModalities = modalities.length > 0 ? modalities : fallbackModalities;
        const modalitiesText = selectedModalities.length > 0 ? formatHumanList(selectedModalities) : "Light microscopy";

        const scannerData = currentInst?.processed_hardware?.scanner || currentInst?.hardware?.scanner || {};
        const scannerFallbackId = (scannerData?.type || scannerData?.id || "").toString().trim();
        const scannerFallbackLabel = scannerFallbackId
            ? formatVocabLabel(vocabularies.scanner_types, scannerFallbackId)
            : "";
        const selectedScanners = scanners.length > 0
            ? scanners
            : (scannerFallbackLabel && scannerFallbackLabel.toLowerCase() !== "none" ? [scannerFallbackLabel] : []);

        const scannerClause = selectedScanners.length > 0
            ? ` equipped with a ${formatHumanList(selectedScanners)} scanner${formatScannerDetails(scannerData)}`
            : "";

        // Base microscope description
        let text = `${modalitiesText} images were acquired using a ${currentInst.manufacturer} ${currentInst.model} ${stand}microscope${scannerClause}, controlled by ${softName}. `;

        if (modules.length > 0) {
            text += `The following hardware modules were utilized: ${formatHumanList(modules)}. `;
            const hasIncubation = modules.some(module => /incubation|incubator|environment|temperature|co2|humidity/i.test(module));
            if (hasIncubation) {
                text += `[PLEASE SPECIFY: Imaging environment setpoints, e.g., temperature (°C), CO2 (%), humidity (%), and stage-top incubation module]. `;
            }
        }

        text += `[PLEASE SPECIFY: Specimen preparation metadata (sample type, labeling strategy, cover glass, and mounting medium)]. `;

        if (objs.length > 0) text += `The system was equipped with the following objective(s): ${objs.join(", ")}. `;
        if (dets.length > 0) text += `Images were captured using: ${dets.join(", ")}. `;
        if (splitters.length > 0) text += `Emission splitting to multiple cameras was performed using: ${splitters.join(", ")}. `;

        const diFilters = filters.filter(f => f.includes('Di:'));
        const emFilters = filters.filter(f => f.includes('Em:'));

        text += `Acquisition used ${lights.length > 0 ? formatHumanList(lights) : '[selected excitation lines]'} with ${diFilters.length > 0 ? formatHumanList(diFilters) : '[main dichroic(s)]'} and ${emFilters.length > 0 ? formatHumanList(emFilters) : '[emission filter(s)]'}. `;
        text += `[PLEASE SPECIFY: Exposure time(s), excitation power(s), camera binning, zoom, line/frame averaging, pixel size (µm/px), z-step (µm), time interval, and tiling overlap where applicable]. `;
        text += `Acquisition parameters should satisfy Nyquist sampling for the selected objective(s) and fluorophore emission profile. `;

        const modalityNeeds = [];
        if (selectedModalities.some(m => /confocal/i.test(m))) modalityNeeds.push('confocal pinhole size and scanner mode (resonant vs galvo)');
        if (selectedModalities.some(m => /sim|structured illumination/i.test(m))) modalityNeeds.push('SIM reconstruction settings and software version');
        if (selectedModalities.some(m => /sted/i.test(m))) modalityNeeds.push('depletion wavelength, power, and depletion timing mode (CW/pulsed)');
        if (selectedModalities.some(m => /flim/i.test(m))) modalityNeeds.push('lifetime fitting model, IRF handling, and photon count thresholds');
        if (selectedModalities.some(m => /tirf/i.test(m))) modalityNeeds.push('incident angle/penetration depth and alignment procedure');
        if (modalityNeeds.length > 0) {
            text += `[PLEASE SPECIFY modality-specific metadata: ${formatHumanList(modalityNeeds)}]. `;
        }

        text += formatProcessingMetadata(currentInst);

        text += `\n\n[DATA AVAILABILITY]: The raw microscopy image files (.nd2/.czi/.lif) generated in this study should be deposited in BioImage Archive or Zenodo to support Open Science and reproducibility; include the accession number or DOI in the final manuscript.`;

        accumulatedMethods.push(text);
        usedInstrumentNames.add(currentInst.display_name.toLowerCase());

        // Uncheck boxes after adding
        document.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false);

        updateOutputText();
    });

    function updateOutputText() {
        if (accumulatedMethods.length === 0) {
            outputText.value = "Please select an instrument and click \"Add to Methods\".";
            return;
        }

        let finalOutput = "Light Microscopy Methods:\n\n";
        finalOutput += accumulatedMethods.join("\n\n");

        // Acknowledgements Section
        finalOutput += "\n\nAcknowledgements:\n\n";

        // Use the dynamically injected text from acknowledgements.yaml
        finalOutput += {{ ack_standard }};

        // Check for xCELLigence usage (partial match on name)
        const usedXcell = Array.from(usedInstrumentNames).some(name => name.toLowerCase().includes("xcelligence"));
        if (usedXcell) {
            finalOutput += " " + {{ ack_xcelligence }};
        }

        outputText.value = finalOutput;
    }

    clearBtn.addEventListener("click", () => {
        accumulatedMethods = [];
        usedInstrumentNames.clear();
        updateOutputText();
    });

    copyBtn.addEventListener("click", () => {
        if (accumulatedMethods.length === 0) return;
        navigator.clipboard.writeText(outputText.value);
        const feedback = document.getElementById("copy-feedback");
        feedback.style.display = "inline";
        setTimeout(() => feedback.style.display = "none", 2000);
    });
});
</script>
