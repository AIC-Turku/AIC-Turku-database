!!! tip "💡 Pro-Tip: Recover exact settings from raw metadata"
    Need exact exposure times, pixel sizes, and laser powers? Use your raw files (`.nd2`, `.czi`, `.lif`, etc.) and let Fiji/ImageJ + an LLM do the extraction for you:

    1. Open the raw image in **Fiji / ImageJ**.
    2. Press **`I`** (or use `Image > Show Info...`) to open complete acquisition metadata.
    3. Copy the metadata text and paste it into an LLM (e.g., ChatGPT/Copilot) with a prompt such as:
       *"Extract exact exposure times, pixel size (xy), z-step, pinhole size, and laser powers from this metadata."*

### Generated Text
<div style="position: relative;">
  <textarea id="output-text" rows="16" style="width: 100%; padding: 15px; border-radius: 4px; border: 1px solid var(--md-default-fg-color--light); background-color: var(--md-code-bg-color); font-family: monospace; line-height: 1.5;" readonly>Please select an instrument and click "Add to Methods".</textarea>
  <div style="margin-top: 10px; display: flex; gap: 10px;">
      <button id="copy-btn" class="md-button md-button--primary">Copy to Clipboard</button>
      <button id="clear-btn" class="md-button">Clear All</button>
      <span id="copy-feedback" style="color: green; margin-top: 8px; display: none;">Copied!</span>
  </div>
</div>

<script>
let vocabularies = {};

document.addEventListener("DOMContentLoaded", async () => {
    const instrumentsResponse = await fetch("../assets/instruments_data.json");
    const instrumentsPayload = await instrumentsResponse.json();
    const instruments = Array.isArray(instrumentsPayload)
        ? instrumentsPayload
        : (instrumentsPayload?.instruments || []);
    vocabularies = instrumentsPayload?.vocabularies || {};

    const systemSelect = document.getElementById("system-select");
    const hwOptions = document.getElementById("hardware-options");
    const outputText = document.getElementById("output-text");
    const copyBtn = document.getElementById("copy-btn");
    const clearBtn = document.getElementById("clear-btn");
    const addBtn = document.getElementById("add-btn");

    let currentInst = null;
    let accumulatedMethods = [];
    let usedInstrumentNames = new Set();

    const methodsMetadataWarning = document.getElementById("methods-metadata-warning");
    const methodsMetadataBlockers = document.getElementById("methods-metadata-blockers");

    // Populate dropdown
    instruments.forEach(inst => {
        const opt = document.createElement("option");
        opt.value = inst.id;
        opt.textContent = inst.retired ? `${inst.display_name} (Retired)` : inst.display_name;
        systemSelect.appendChild(opt);
    });


    function formatBlockerLabel(blocker) {
        const title = (blocker?.title || blocker?.path || "Missing field").toString().trim();
        const role = (blocker?.role || "").toString().trim();
        if (role) return `${title} (${toTitleCase(role)} software)`;
        return title;
    }

    function getMethodsMetadataStatus(inst) {
        const metadata = inst?.methods_generation || {};
        const blockers = Array.isArray(metadata?.blockers)
            ? metadata.blockers.filter(item => item?.kind === "instrument_metadata")
            : [];

        return {
            isBlocked: Boolean(metadata?.is_blocked) && blockers.length > 0,
            blockers,
            softwareByRole: metadata?.software_by_role || {},
        };
    }

    function renderMethodsMetadataWarning(inst) {
        const status = getMethodsMetadataStatus(inst);
        methodsMetadataBlockers.innerHTML = "";

        if (!status.isBlocked) {
            methodsMetadataWarning.style.display = "none";
            return status;
        }

        status.blockers.forEach(blocker => {
            const item = document.createElement("li");
            item.textContent = formatBlockerLabel(blocker);
            methodsMetadataBlockers.appendChild(item);
        });

        methodsMetadataWarning.style.display = "block";
        return status;
    }

    systemSelect.addEventListener("change", (e) => {
        const instId = e.target.value;
        currentInst = instruments.find(i => i.id === instId);

        if (!currentInst) {
            hwOptions.style.display = "none";
            methodsMetadataWarning.style.display = "none";
            methodsMetadataBlockers.innerHTML = "";
            return;
        }

        hwOptions.style.display = "block";
        renderMethodsMetadataWarning(currentInst);

        const dto = currentInst?.dto || currentInst;

        bindCheckboxes("modality-list", dto.modalities || [], "modality");
        bindCheckboxes("module-list", dto.modules || [], "module");
        bindCheckboxes("scanner-list", dto.hardware?.scanner?.present ? [dto.hardware.scanner] : [], "scanner");
        bindCheckboxes("obj-list", dto.hardware?.objectives || [], "obj");
        bindCheckboxes("light-list", dto.hardware?.light_sources || [], "light");
        bindCheckboxes("det-list", dto.hardware?.detectors || [], "det");

        const opticalPath = dto.hardware?.optical_path || {};
        bindCheckboxes("filter-list", opticalPath.filters || [], "filter");
        bindCheckboxes("splitter-list", opticalPath.splitters || [], "splitter");
    });

    function bindCheckboxes(containerId, items, prefix) {
        const container = document.getElementById(containerId);
        container.innerHTML = "";

        if (!Array.isArray(items) || items.length === 0) {
            container.innerHTML = "<span style='color: gray; font-size: 0.9em;'>No data available.</span>";
            return;
        }

        items.forEach((item, index) => {
            const wrapper = document.createElement("div");
            wrapper.style.marginBottom = "4px";

            const checkbox = document.createElement("input");
            checkbox.type = "checkbox";
            checkbox.id = `${prefix}-${index}`;
            checkbox.value = item.id || `${prefix}-${index}`;
            checkbox.dataset.displayLabel = item.display_label || "";
            checkbox.dataset.methodSentence = item.method_sentence || "";

            const label = document.createElement("label");
            label.htmlFor = checkbox.id;
            label.textContent = " " + (item.display_label || "Unnamed item");

            wrapper.appendChild(checkbox);
            wrapper.appendChild(label);

            if (item.display_subtitle) {
                const sub = document.createElement("div");
                sub.textContent = item.display_subtitle;
                sub.style.fontSize = "0.8em";
                sub.style.fontStyle = "italic";
                sub.style.color = "gray";
                sub.style.marginLeft = "24px";
                wrapper.appendChild(sub);
            }

            container.appendChild(wrapper);
        });
    }

    function getCheckedMethodSentences(prefix) {
        return Array.from(document.querySelectorAll(`input[id^="${prefix}-"]:checked`))
            .map(cb => cb.dataset.methodSentence)
            .filter(Boolean);
    }

    addBtn.addEventListener("click", () => {
        if (!currentInst) return;

        const dto = currentInst?.dto || currentInst;
        const methodsMetadataStatus = getMethodsMetadataStatus(currentInst);
        if (methodsMetadataStatus.isBlocked) {
            renderMethodsMetadataWarning(currentInst);
            const blockerSummary = methodsMetadataStatus.blockers
                .map(blocker => blocker.title || blocker.path || "Missing field")
                .join(", ");
            accumulatedMethods.push(`Methods text for ${dto.display_name} cannot be generated yet because required instrument metadata is missing: ${blockerSummary}.`);
            updateOutputText();
            return;
        }

        const textParts = [
            dto.methods?.base_sentence,
            ...getCheckedMethodSentences("modality"),
            ...getCheckedMethodSentences("module"),
            ...getCheckedMethodSentences("scanner"),
            dto.methods?.environment_sentence,
            ...(dto.methods?.stage_sentences || []),
            dto.methods?.autofocus_sentence,
            dto.methods?.triggering_sentence,
            ...getCheckedMethodSentences("obj"),
            ...getCheckedMethodSentences("det"),
            ...getCheckedMethodSentences("light"),
            ...getCheckedMethodSentences("filter"),
            ...getCheckedMethodSentences("splitter"),
            ...(dto.methods?.processing_sentences || []),
            "[PLEASE SPECIFY: Specimen preparation metadata (sample type, labeling strategy, cover glass, and mounting medium)].",
            "[PLEASE SPECIFY: Exposure time(s), excitation power(s), camera binning, zoom, line/frame averaging, pixel size (µm/px), z-step (µm), time interval, and tiling overlap where applicable].",
            "Acquisition parameters should satisfy Nyquist sampling for the selected objective(s) and fluorophore emission profile.",
            "[DATA AVAILABILITY]: The raw microscopy image files (.nd2/.czi/.lif) generated in this study should be deposited in BioImage Archive or Zenodo to support Open Science and reproducibility; include the accession number or DOI in the final manuscript.",
        ].filter(Boolean);

        accumulatedMethods.push(textParts.join(" "));
        updateOutputText();
    });

    function updateOutputText() {
        if (accumulatedMethods.length === 0) {
            outputText.value = "Please select an instrument and click \"Add to Methods\".";
            return;
        }

        let finalOutput = "Light Microscopy Methods:\n\n";
        finalOutput += accumulatedMethods.join("\n\n");

        // Acknowledgements Section
        finalOutput += "\n\nAcknowledgements:\n\n";

        // Use the dynamically injected text from acknowledgements.yaml
        finalOutput += {{ ack_standard }};

        // Check for xCELLigence usage (partial match on name)
        const usedXcell = Array.from(usedInstrumentNames).some(name => name.toLowerCase().includes("xcelligence"));
        if (usedXcell) {
            finalOutput += " " + {{ ack_xcelligence }};
        }

        outputText.value = finalOutput;
    }

    clearBtn.addEventListener("click", () => {
        accumulatedMethods = [];
        usedInstrumentNames.clear();
        updateOutputText();
    });

    copyBtn.addEventListener("click", () => {
        if (accumulatedMethods.length === 0) return;
        navigator.clipboard.writeText(outputText.value);
        const feedback = document.getElementById("copy-feedback");
        feedback.style.display = "inline";
        setTimeout(() => feedback.style.display = "none", 2000);
    });
});
</script>
