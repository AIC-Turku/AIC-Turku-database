  - toc
---
# 🔬 Optical Flow Simulator

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.6/dist/chart.umd.min.js"></script>
<style>
  .vm-page {
    --surface: var(--md-default-bg-color);
    --text: var(--md-default-fg-color);
    --muted: var(--md-default-fg-color--light);
    --border: var(--md-default-fg-color--lighter);
    --primary: var(--md-primary-fg-color);
    --danger: #dc2626;

    width: 100%;
    display: flex;
    flex-direction: column;
    gap: 14px;
    margin-top: 12px;
  }
  .vm-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: var(--md-shadow-z1);
    color: var(--text);
    padding: 14px;
  }
  .vm-main {
    display: grid;
    gap: 14px;
    grid-template-columns: 1fr;
    align-items: start;
  }
  .vm-main-left,
  .vm-main-right,
  .vm-stack {
    display: grid;
    gap: 14px;
    min-width: 0;
  }
  .vm-section-title {
    margin: 0 0 6px;
    font-size: 13px;
    color: var(--muted);
    letter-spacing: 0.05em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .vm-panel-copy {
    font-size: 12px;
    color: var(--muted);
    margin: 2px 0 10px;
    line-height: 1.45;
  }
  .vm-field { display: flex; flex-direction: column; gap: 6px; margin-bottom: 8px; }
  .vm-field label { font-size: 12px; font-weight: 600; }
  .vm-field select,
  .vm-field input[type="text"] {
    width: 100%;
    border-radius: 6px;
    border: 1px solid var(--border);
    padding: 8px 10px;
    font: inherit;
    font-size: 13px;
    background: var(--surface);
    color: var(--text);
  }
  .vm-btn {
    border: none;
    background: var(--primary);
    color: #fff;
    border-radius: 6px;
    padding: 8px 12px;
    cursor: pointer;
    font-weight: 600;
    font-size: 13px;
  }
  .vm-btn-primary { background: linear-gradient(135deg, var(--primary), #7c3aed); }
  .vm-search-grid {
    display: grid;
    gap: 12px;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    align-items: start;
  }
  .vm-search-box {
    position: relative;
    display: grid;
    gap: 6px;
    padding: 10px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: rgba(148, 163, 184, 0.06);
  }
  .vm-search-box-header {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: center;
  }
  .vm-search-box-title {
    font-size: 12px;
    font-weight: 700;
    color: var(--text);
  }
  .vm-search-box-subtitle { font-size: 11px; color: var(--muted); }
  .fp-search-wrap { position: relative; display: flex; gap: 8px; }
  .fp-dropdown {
    position: absolute;
    top: calc(100% + 2px);
    left: 0;
    right: 0;
    background: var(--surface);
    border: 1px solid var(--border);
    z-index: 100;
    max-height: 220px;
    overflow-y: auto;
    border-radius: 8px;
    box-shadow: 0 8px 18px rgba(0,0,0,0.12);
    display: none;
    list-style: none;
    margin: 0;
    padding: 0;
  }
  .fp-dropdown li { padding: 8px 12px; cursor: pointer; font-size: 13px; border-bottom: 1px solid var(--border); }
  .fp-dropdown li:hover { background: var(--md-code-bg-color); }
  .vm-mini { font-size: 11px; color: var(--muted); }
  .vm-status-inline { min-height: 16px; margin: 0; font-size: 11px; color: var(--muted); }
  .vm-status-inline[data-tone="error"] { color: var(--danger); font-weight: 700; }
  .vm-status-inline[data-tone="warning"] { color: #b45309; font-weight: 700; }
  .vm-status-inline[data-tone="success"] { color: #059669; font-weight: 700; }
  .vm-list { list-style: none; margin: 0; padding: 0; display: flex; flex-direction: column; gap: 8px; }
  .vm-list-item {
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: 8px 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
    gap: 12px;
    background: rgba(148, 163, 184, 0.04);
  }
  .dye-chip { border-color: #fecaca; color: var(--danger); width: max-content; background: rgba(254, 242, 242, 0.7); }
  .dye-chip button { background: none; border: none; color: inherit; cursor: pointer; font-weight: bold; margin-left: 8px; }
  .vm-loaded-row {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 10px;
  }
  .vm-chart-stack { display: grid; gap: 10px; margin-top: 10px; }
  .vm-chart-panel {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 10px;
    background: var(--surface);
  }
  .vm-chart-header {
    display: flex;
    justify-content: space-between;
    gap: 12px;
    align-items: flex-start;
    margin-bottom: 8px;
  }
  .vm-chart-title { font-size: 12px; font-weight: 700; color: var(--text); }
  .vm-chart-subtitle { font-size: 11px; color: var(--muted); }
  .vm-chart-wrap { background: var(--surface); border-radius: 12px; padding: 4px; height: 280px; }
  .vm-chart-wrap.vm-chart-wrap-short { height: 250px; }
  .vm-path-head {
    display:flex;
    justify-content:space-between;
    align-items:flex-start;
    gap:12px;
    flex-wrap:wrap;
    margin-bottom: 10px;
  }
  .vm-route-field { margin: 0; min-width: 220px; }
  .vm-utility-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    flex-wrap: wrap;
    margin-bottom: 10px;
  }
  .vm-autoconfig-status { min-height: 18px; margin: 0; font-size: 11px; color: var(--muted); }
  .vm-autoconfig-status[data-tone="success"] { color: #059669; font-weight: 700; }
  .vm-autoconfig-status[data-tone="warning"] { color: #b45309; font-weight: 700; }
  .vm-summary-grid {
    display:grid;
    gap:8px 12px;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    font-size:13px;
    margin: 10px 0 0;
    padding:10px;
    border-radius:8px;
    background: var(--md-code-bg-color);
    border:1px dashed var(--border);
  }

  .light-path-graph {
    display: flex;
    flex-direction: column;
    align-items: stretch;
    gap: 12px;
    padding: 12px;
    background: var(--md-code-bg-color);
    border-radius: 12px;
    border: 1px solid var(--border);
  }
  .vm-pipeline-shell {
    display: grid;
    gap: 14px;
    grid-template-columns: minmax(0, 1.35fr) minmax(320px, 1fr);
    align-items: start;
  }
  .vm-pipeline {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 10px;
    overflow-x: auto;
    padding: 12px;
    border-radius: 14px;
    border: 1px solid var(--border);
    background: rgba(148, 163, 184, 0.08);
  }
  .vm-stage-tab {
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    border-radius: 999px;
    padding: 8px 14px;
    white-space: nowrap;
    font-weight: 700;
    font-size: 12px;
    cursor: pointer;
    box-shadow: var(--md-shadow-z1);
  }
  .vm-stage-tab.active {
    border-color: var(--primary);
    color: var(--primary);
    box-shadow: 0 0 0 1px color-mix(in srgb, var(--primary) 22%, transparent), var(--md-shadow-z1);
  }
  .optical-pipe {
    flex: 1 1 56px;
    min-width: 56px;
    height: 12px;
    border-radius: 999px;
    border: 1px solid rgba(148, 163, 184, 0.32);
    background: linear-gradient(90deg, rgba(148, 163, 184, 0.08), rgba(148, 163, 184, 0.22));
    overflow: hidden;
    position: relative;
  }
  .flowing-light {
    --beam-color: transparent;
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(90deg,
      color-mix(in srgb, var(--beam-color) 20%, transparent) 0px,
      var(--beam-color) 12px,
      color-mix(in srgb, var(--beam-color) 75%, white) 24px,
      var(--beam-color) 36px,
      color-mix(in srgb, var(--beam-color) 20%, transparent) 48px);
    background-size: 180px 100%;
    animation: vm-flow-light 1.8s linear infinite;
    opacity: 0.95;
  }
  .flowing-light[data-empty="true"] { opacity: 0.15; }
  .flowing-light[data-empty="false"] {
    box-shadow: 0 0 18px color-mix(in srgb, var(--beam-color) 42%, transparent);
  }
  @keyframes vm-flow-light {
    from { background-position: 0 0; }
    to { background-position: 180px 0; }
  }
  .vm-inspector {
    border: 1px solid var(--border);
    border-radius: 12px;
    background: var(--surface);
    padding: 16px;
    box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
  }
  .vm-stage-panel { display: none; gap: 10px; }
  .vm-stage-panel.active { display: grid; }
  .vm-stage-panel-title { font-size: 13px; font-weight: 800; color: var(--primary); text-transform: uppercase; }
  .vm-component-meta {
    display: grid;
    gap: 4px;
    margin-top: 6px;
    padding: 8px 10px;
    border-radius: 8px;
    border: 1px dashed var(--border);
    background: rgba(148, 163, 184, 0.08);
    font-size: 11px;
    color: var(--muted);
  }
  .vm-linked-note {
    display: grid;
    gap: 6px;
    padding: 10px;
    border-radius: 10px;
    background: rgba(var(--md-primary-fg-color--rgb), 0.05);
    border: 1px solid var(--border);
  }
  .vm-linked-note-title { font-weight: 700; font-size: 12px; color: var(--primary); }
  .checkbox-group { display: flex; flex-direction: column; gap: 6px; }
  .checkbox-group label { display: flex; align-items: center; gap: 6px; font-size: 12px; cursor: pointer; font-weight: normal; }
  .tunable-control { border: 1px dashed var(--border); padding: 8px; border-radius: 6px; display: grid; gap: 6px; background: var(--md-code-bg-color); }
  .tunable-range-label { font-size: 11px; text-align: center; font-weight: bold; }
  .slider-row input[type="range"] { width: 100%; margin: 2px 0; accent-color: var(--primary); }
  .vm-source-grid { display:grid; gap:8px; grid-template-columns: repeat(auto-fit, minmax(170px, 1fr)); }
  .vm-source-group-title { grid-column: 1 / -1; }
  .vm-metric { font-family: monospace; font-size: 12px; text-align: right; white-space: nowrap; }
  .vm-side-chart { height: 260px; margin-bottom: 10px; }
  .vm-card-column { display: grid; gap: 10px; }
  .vm-info-card {
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 10px;
    background: rgba(148, 163, 184, 0.05);
    display: grid;
    gap: 6px;
  }
  .vm-info-card-title { font-size: 13px; font-weight: 700; }
  .vm-info-card-subtitle { font-size: 11px; color: var(--muted); }
  .vm-info-grid { display: grid; gap: 4px; }
  .vm-info-row { display: flex; justify-content: space-between; gap: 12px; font-size: 11px; }
  .vm-info-row strong { color: var(--text); }
  .vm-results-grid {
    display: grid;
    gap: 14px;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    align-items: start;
  }
  .vm-results-chart-panel,
  .vm-results-scoreboard {
    display: grid;
    gap: 10px;
  }
  .vm-results-panel .vm-panel-copy {
    margin-bottom: 0;
  }
  .vm-side-chart {
    height: 320px;
    margin-bottom: 0;
  }
  .vm-splitter-card {
    border-style: solid;
    border-width: 1px;
    border-color: color-mix(in srgb, var(--primary) 25%, var(--border));
    background: linear-gradient(180deg, rgba(var(--md-primary-fg-color--rgb), 0.05), rgba(148, 163, 184, 0.06));
  }
  .vm-branch-list {
    display: grid;
    gap: 8px;
    margin-top: 6px;
  }
  .vm-branch-row {
    position: relative;
    display: grid;
    gap: 4px;
    padding: 10px 10px 10px 14px;
    border: 1px solid var(--border);
    border-radius: 10px;
    background: rgba(255, 255, 255, 0.02);
    overflow: hidden;
  }
  .vm-branch-row::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 3px;
    background: color-mix(in srgb, var(--primary) 50%, transparent);
  }

  @media (max-width: 1100px) {
    .vm-main,
    .vm-pipeline-shell,
    .vm-results-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<div class="vm-page">
  <header class="vm-panel" style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px;">
    <div>
      <h2 class="vm-section-title" style="margin:0;">Microscope System</h2>
      <p style="font-size:12px; color:var(--muted); margin:2px 0 0 0;">Select a system to load its physical light path configuration.</p>
    </div>
    <div class="vm-field" style="margin:0; flex-grow:1; max-width:420px;">
      <select id="microscopeSelector" style="font-size:14px; padding:10px; font-weight:bold;"></select>
    </div>
  </header>

  <main class="vm-main">
    <div class="vm-main-left">
      <section class="vm-panel">
        <h2 class="vm-section-title">1. Fluorophore Reference Spectra</h2>
        <p class="vm-panel-copy">Use the local dye library and FPbase separately. The top chart focuses on excitation light reaching the sample; the lower chart focuses on emitted light that survives the collection path.</p>

        <div class="vm-search-grid">
          <div class="vm-search-box">
            <div class="vm-search-box-header">
              <div>
                <div class="vm-search-box-title">Local dye library</div>
                <div class="vm-search-box-subtitle">Search imported spectra from <code>assets/data/spectra/fluorophores/</code>.</div>
              </div>
            </div>
            <div class="fp-search-wrap">
              <input id="localFluorophoreQuery" type="text" placeholder="e.g. AF488" style="flex:1; border-radius:6px; border:1px solid var(--border); padding:8px;"/>
              <button id="localSearchBtn" class="vm-btn">Search</button>
              <ul id="localSearchResults" class="fp-dropdown"></ul>
            </div>
            <p id="localSearchStatus" class="vm-status-inline"></p>
          </div>

          <div class="vm-search-box">
            <div class="vm-search-box-header">
              <div>
                <div class="vm-search-box-title">FPbase proteins</div>
                <div class="vm-search-box-subtitle">Search FPbase remotely. Local dyes remain separate and are not mixed into this menu.</div>
              </div>
            </div>
            <div class="fp-search-wrap">
              <input id="fluorophoreQuery" type="text" placeholder="e.g. GFP, mCherry, mNeonGreen" style="flex:1; border-radius:6px; border:1px solid var(--border); padding:8px;"/>
              <button id="searchBtn" class="vm-btn">Search</button>
              <ul id="searchResults" class="fp-dropdown"></ul>
            </div>
            <p id="searchStatus" class="vm-status-inline"></p>
          </div>
        </div>

        <div class="vm-loaded-row">
          <div>
            <h3 class="vm-section-title" style="margin:0 0 4px;">Loaded fluorophores</h3>
            <div class="vm-mini">Loaded local dyes and FPbase proteins share the same downstream simulation.</div>
          </div>
          <label style="display:flex; align-items:center; gap:8px; font-size:12px; cursor:pointer; margin:0;">
            <input id="use2Photon" type="checkbox" />
            <span>Use 2-photon spectra when available</span>
          </label>
        </div>
        <ul id="selectedDyes" style="display:flex; flex-wrap:wrap; gap:8px; padding:0; margin:10px 0 0 0;">
          <li style="font-size:12px; color:var(--muted);">No dyes loaded.</li>
        </ul>

        <div class="vm-chart-stack">
          <div class="vm-chart-panel">
            <div class="vm-chart-header">
              <div>
                <div class="vm-chart-title">Excitation arriving at the sample</div>
                <div class="vm-chart-subtitle">Absorption spectra are compared against the selected excitation light after excitation-side optics.</div>
              </div>
              <p id="referenceStatus" class="vm-status-inline"></p>
            </div>
            <div class="vm-chart-wrap vm-chart-wrap-short">
              <canvas id="referenceSpectraChart"></canvas>
            </div>
          </div>

          <div class="vm-chart-panel">
            <div class="vm-chart-header">
              <div>
                <div class="vm-chart-title">Emission and collection</div>
                <div class="vm-chart-subtitle">Full fluorophore emission is shown alongside the part that survives the collection filters and detector window.</div>
              </div>
              <p id="emissionStatus" class="vm-status-inline"></p>
            </div>
            <div class="vm-chart-wrap vm-chart-wrap-short">
              <canvas id="propagationSpectraChart"></canvas>
            </div>
          </div>
        </div>
      </section>
    </div>
  </main>

  <section class="vm-panel">
    <div class="vm-path-head">
      <div>
        <h2 class="vm-section-title">2. Controlling the Optical Path</h2>
        <p class="vm-panel-copy">Choose the microscope route, then tune the optics and light sources below. The pipe colors visualize how the spectrum evolves along the path.</p>
      </div>
      <div id="opticalRouteChooserWrap" class="vm-field vm-route-field" style="display:none;">
        <label for="opticalRouteSelector">Optical route</label>
        <select id="opticalRouteSelector"></select>
      </div>
    </div>
    <div class="vm-utility-row">
      <button id="vm-btn-autoconfig" class="vm-btn vm-btn-primary">✨ Auto-Configure optimal path</button>
      <p id="vm-autoconfig-status" class="vm-autoconfig-status"></p>
    </div>
    <div id="lightPathGraph" class="light-path-graph"></div>
    <div id="pathSummary" class="vm-summary-grid"></div>
  </section>

  <section class="vm-panel vm-results-panel">
    <div class="vm-path-head">
      <div>
        <h2 class="vm-section-title">3. Collected Light per Fluorophore</h2>
        <p class="vm-panel-copy">Results now live below the pipeline so the optical workspace stays wide. Each endpoint receives its own routed path, benchmark score, and leakage readout.</p>
      </div>
    </div>
    <div class="vm-results-grid">
      <div class="vm-results-chart-panel">
        <div class="vm-chart-wrap vm-side-chart">
          <canvas id="detectionChart"></canvas>
        </div>
      </div>
      <div class="vm-results-scoreboard">
        <div id="signalSimulator" class="vm-card-column">
          <div class="vm-info-card">
            <div class="vm-info-card-title">No simulation yet</div>
            <div class="vm-info-card-subtitle">Load a fluorophore, then configure excitation and detection to compare collection efficiency.</div>
          </div>
        </div>
      </div>
    </div>
  </section>
</div>

<script id="lightpath-data" type="application/json">
  {{ lightpath_data_json | safe }}
</script>

<script>
{% include 'virtual_microscope_runtime.js' %}
</script>

<script>
{% include 'virtual_microscope_app.js' %}
</script>
