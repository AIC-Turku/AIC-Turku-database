# 🔬 Virtual Microscope & Spectra Viewer

<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.6/dist/chart.umd.min.js"></script>
<style>
  .vm-page {
    --surface: var(--md-default-bg-color);
    --surface-2: var(--md-default-fg-color--lightest);
    --text: var(--md-default-fg-color);
    --muted: var(--md-default-fg-color--light);
    --border: var(--md-default-fg-color--lighter);
    --primary: var(--md-primary-fg-color);
    --danger: #dc2626;

    width: 100%;
    display: grid;
    grid-template-columns: minmax(300px, 350px) 1fr;
    gap: 20px;
    align-items: start;
    margin-top: 20px;
  }
  .vm-panel {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 12px;
    box-shadow: var(--md-shadow-z1);
    color: var(--text);
  }
  .vm-controls {
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 20px;
    max-height: calc(100vh - 120px);
    overflow-y: auto;
  }
  .vm-section-title {
    margin: 0 0 12px;
    font-size: 14px;
    color: var(--muted);
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 700;
  }
  .vm-mechanism-group {
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 12px;
    background: var(--md-code-bg-color);
  }
  .vm-field {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 10px;
  }
  .vm-field label {
    font-size: 13px;
    font-weight: 600;
  }
  .vm-field select, .vm-field input[type="text"] {
    width: 100%;
    border-radius: 8px;
    border: 1px solid var(--border);
    padding: 10px 12px;
    font: inherit;
    background: var(--surface);
    color: var(--text);
  }
  .vm-field select:focus, .vm-field input:focus {
    outline: none;
    border-color: var(--primary);
  }
  .vm-btn {
    width: 100%;
    border: none;
    background: var(--primary);
    color: #fff;
    border-radius: 8px;
    padding: 10px 12px;
    cursor: pointer;
    font-weight: 600;
  }
  .vm-list {
    list-style: none;
    margin: 8px 0 0;
    padding: 0;
    display: grid;
    gap: 8px;
    max-height: 200px;
    overflow-y: auto;
  }
  .vm-list-item {
    border: 1px solid var(--border);
    background: var(--surface);
    border-radius: 8px;
    padding: 8px 10px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 13px;
  }
  .vm-list-item button {
    padding: 4px 8px;
    border-radius: 8px;
    border: 1px solid var(--border);
    background: var(--surface);
    color: var(--text);
    cursor: pointer;
    font-size: 12px;
  }
  .vm-list-item.dye-chip button { border-color: #fecaca; color: var(--danger); }
  .vm-status { margin-top: 8px; font-size: 12px; color: var(--muted); }
  .vm-chart-panel {
    padding: 14px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    min-height: 600px;
  }
  .vm-chart-wrap {
    flex: 1;
    background: #fff; /* Enforce white to ensure chart colors look accurate in dark mode */
    border-radius: 12px;
    padding: 10px;
    border: 1px solid var(--border);
    min-height: 400px;
  }
  .vm-path-summary {
    padding: 10px 12px;
    border: 1px dashed var(--muted);
    border-radius: 8px;
    background: var(--md-code-bg-color);
    font-size: 13px;
    min-height: 40px;
    display: flex;
    align-items: center;
  }
  .vm-simulator-item {
    border: 1px solid var(--border);
    background: var(--surface);
    border-radius: 8px;
    padding: 8px 10px;
    font-size: 13px;
  }
  .tunable-control { border: 1px solid var(--border); border-radius: 10px; padding: 10px; background: var(--surface); display: grid; gap: 10px; }
  .tunable-range-label { font-size: 12px; color: var(--muted); font-weight: 600; }
  .slider-row { display: grid; gap: 6px; }
  .slider-row input[type="range"] { padding: 0; accent-color: var(--primary); }
  @media (max-width: 1024px) { .vm-page { grid-template-columns: 1fr; } .vm-controls { max-height: none; } }
</style>

<div class="vm-page">
  <aside class="vm-panel vm-controls">
    <section>
      <h2 class="vm-section-title">Microscope</h2>
      <div class="vm-field">
        <label for="microscopeSelector">Select instrument</label>
        <select id="microscopeSelector"></select>
      </div>
    </section>

    <section>
      <h2 class="vm-section-title">Hardware Configuration</h2>
      <div id="controlContainer"></div>
    </section>

    <section>
      <h2 class="vm-section-title">Fluorophore Search</h2>
      <div class="vm-field">
        <label for="fluorophoreQuery">Protein / dye name</label>
        <input id="fluorophoreQuery" type="text" placeholder="e.g. GFP, mCherry, Alexa" />
      </div>
      <button id="searchBtn" class="vm-btn" type="button">Search FPbase</button>
      <p id="searchStatus" class="vm-status"></p>
      <ul id="searchResults" class="vm-list"></ul>
    </section>

    <section>
      <h2 class="vm-section-title">Added Fluorophores</h2>
      <ul id="selectedDyes" class="vm-list"></ul>
    </section>
  </aside>

  <section class="vm-panel vm-chart-panel">
    <div id="pathSummary" class="vm-path-summary" aria-live="polite"></div>
    <div class="vm-chart-wrap">
      <canvas id="spectraChart"></canvas>
    </div>
    <div class="vm-mechanism-group" aria-live="polite">
      <h2 class="vm-section-title" style="margin: 0;">Signal Simulator</h2>
      <ul id="signalSimulator" class="vm-list">
        <li class="vm-simulator-item">Add a fluorophore to compute excitation/collection efficiency.</li>
      </ul>
    </div>
  </section>
</div>

<script id="lightpath-data" type="application/json">
  {{ lightpath_data_json | safe }}
</script>

<script>
  (function() {
    let globalData = {};
    try {
      const raw = document.getElementById('lightpath-data').textContent.trim();
      if (raw) globalData = JSON.parse(raw);
    } catch (err) {
      console.error('Failed to parse lightpath payload', err);
    }

    const state = {
      allInstruments: globalData,
      activeInstrument: null,
      loadedProteins: new Map(),
    };
    let currentInstrumentId = null;

    const chartCanvas = document.getElementById('spectraChart');
    const microscopeSelector = document.getElementById('microscopeSelector');
    const controlContainer = document.getElementById('controlContainer');
    const searchBtn = document.getElementById('searchBtn');
    const fluorophoreQuery = document.getElementById('fluorophoreQuery');
    const searchStatus = document.getElementById('searchStatus');
    const searchResults = document.getElementById('searchResults');
    const selectedDyesList = document.getElementById('selectedDyes');
    const pathSummary = document.getElementById('pathSummary');
    const signalSimulator = document.getElementById('signalSimulator');

    let chartInstance = null;

    function init() {
      initChart();
      const entries = Object.entries(state.allInstruments);
      if (!entries.length) {
        controlContainer.innerHTML = '<p class="vm-status">No hardware data available.</p>';
        return;
      }

      microscopeSelector.innerHTML = '';
      entries.forEach(([instrumentId, instrumentData]) => {
        const option = document.createElement('option');
        option.value = instrumentId;
        // Fix #3: Use display_name so it looks clean
        const name = instrumentData?.display_name || instrumentData?.name || instrumentId;
        option.textContent = name;
        microscopeSelector.appendChild(option);
      });

      const params = new URLSearchParams(window.location.search);
      const requestedScope = params.get('scope');

      if (requestedScope && Object.prototype.hasOwnProperty.call(state.allInstruments, requestedScope)) {
        microscopeSelector.value = requestedScope;
        currentInstrumentId = requestedScope;
      } else {
        microscopeSelector.value = entries[0][0];
        currentInstrumentId = entries[0][0];
      }

      microscopeSelector.addEventListener('change', (e) => {
        currentInstrumentId = e.target.value;
        loadInstrument(currentInstrumentId);
      });

      loadInstrument(currentInstrumentId);

      searchBtn.addEventListener('click', () => searchFPbase(fluorophoreQuery.value));
      fluorophoreQuery.addEventListener('keypress', (e) => {
        if (e.key === 'Enter') searchFPbase(fluorophoreQuery.value);
      });
      fluorophoreQuery.addEventListener('input', debounce(() => searchFPbase(fluorophoreQuery.value), 300));
    }

    function loadInstrument(id) {
      state.activeInstrument = normalizeMechanisms(state.allInstruments[id] || {});
      renderControls();
      drawHardware();
      calculateEfficiencies();
    }

    function initChart() {
      chartInstance = new Chart(chartCanvas, {
        type: 'line',
        data: { datasets: [] },
        options: {
          responsive: true,
          maintainAspectRatio: false,
          interaction: { mode: 'index', intersect: false },
          plugins: {
            tooltip: { enabled: true },
            legend: { position: 'bottom', labels: { boxWidth: 12 } }
          },
          scales: {
            x: { type: 'linear', title: { display: true, text: 'Wavelength (nm)' }, min: 350, max: 800 },
            y: { title: { display: true, text: 'Transmission / Intensity (%)' }, min: 0, max: 105 }
          }
        }
      });
    }

    // API Fix #2: Use correct endpoint query & accurate DRF filtering
    async function searchFPbase(query) {
      const trimmed = String(query || '').trim();
      if (!trimmed || trimmed.length < 3) {
        searchResults.innerHTML = '';
        searchStatus.textContent = trimmed ? 'Type at least 3 characters...' : '';
        return;
      }
      searchStatus.textContent = 'Searching FPbase...';
      searchResults.innerHTML = '';

      const url = `https://www.fpbase.org/api/proteins/?name__icontains=${encodeURIComponent(trimmed)}&format=json`;
      try {
        const response = await fetch(url, { headers: { 'Accept': 'application/json' } });
        if (!response.ok) throw new Error(`FPbase search failed (${response.status})`);
        const data = await response.json();

        let results = Array.isArray(data) ? data : (data?.results || [data]);
        const lowerQuery = trimmed.toLowerCase();
        results = results.filter((protein) => protein?.name && protein.name.toLowerCase().includes(lowerQuery));

        searchStatus.textContent = results.length ? `Found ${results.length} results.` : 'No matches found.';

        results.slice(0, 15).forEach((protein) => {
          const li = document.createElement('li');
          li.className = 'vm-list-item';
          li.style.cursor = 'pointer';
          li.textContent = protein.name + (protein.exMax ? ` (Ex: ${protein.exMax} / Em: ${protein.emMax})` : '');
          li.onclick = () => {
            loadProteinDetail(protein.slug || protein.id);
            searchResults.innerHTML = '';
            searchStatus.textContent = `Loaded ${protein.name}`;
          };
          searchResults.appendChild(li);
        });
      } catch (err) {
        searchStatus.textContent = 'Error connecting to FPbase.';
        console.error(err);
      }
    }

    async function loadProteinDetail(slugOrId) {
      if (state.loadedProteins.has(slugOrId)) return;
      try {
        const detailUrl = `https://www.fpbase.org/api/proteins/${encodeURIComponent(slugOrId)}/?format=json`;
        const resp = await fetch(detailUrl, { headers: { 'Accept': 'application/json' } });
        if (!resp.ok) throw new Error(`Detail fetch failed`);
        const detail = await resp.json();

        state.loadedProteins.set(slugOrId, { id: slugOrId, detail });
        upsertSelectedDyeList();
        drawHardware();
        calculateEfficiencies();
      } catch (err) {
        console.error('Failed to load protein spectra', err);
      }
    }

    // Fix #4: Correctly map DRF spectrum_type vs subtype
    function extractSpectra(proteinDetail) {
      const states = proteinDetail?.states || [];
      const defaultState = states.length > 0 ? states[0] : (proteinDetail?.default_state || {});
      const spectraContainer = defaultState.spectra || proteinDetail?.spectra || [];
      const spectra = Array.isArray(spectraContainer) ? spectraContainer : [];

      const excitation = spectra.find((s) => String(s.spectrum_type || s.type || s.subtype || s.category || '').toLowerCase().includes('ex'));
      const emission = spectra.find((s) => String(s.spectrum_type || s.type || s.subtype || s.category || '').toLowerCase().includes('em'));

      return {
        excitation: pointsFromSeries(excitation?.data || excitation?.values || excitation?.points || []),
        emission: pointsFromSeries(emission?.data || emission?.values || emission?.points || []),
      };
    }

    function pointsFromSeries(series) {
      if (!Array.isArray(series)) return [];
      const rawPoints = series.map((item) => {
        if (!item) return null;
        if (Array.isArray(item) && item.length >= 2) return { x: Number(item[0]), y: Number(item[1]) };
        if (typeof item === 'object') return { x: Number(item.x ?? item.wavelength ?? item.wl), y: Number(item.y ?? item.value ?? item.intensity) };
        return null;
      }).filter(p => p !== null && Number.isFinite(p.x) && Number.isFinite(p.y));

      if (!rawPoints.length) return [];

      const maxY = Math.max(...rawPoints.map(p => p.y));
      const scale = (maxY > 0 && maxY <= 1.05) ? 100 : 1;
      return rawPoints.map(p => ({ x: p.x, y: p.y * scale })).sort((a, b) => a.x - b.x);
    }

    function upsertSelectedDyeList() {
      selectedDyesList.innerHTML = '';
      if (state.loadedProteins.size === 0) {
        selectedDyesList.innerHTML = '<li class="vm-status" style="list-style: none">No dyes added yet.</li>';
        return;
      }
      state.loadedProteins.forEach((item, id) => {
        const li = document.createElement('li');
        li.className = 'vm-list-item dye-chip';
        const color = wavelengthToColorHex(item.detail.emMax || 520);
        li.innerHTML = `<span style="border-left: 4px solid ${color}; padding-left: 6px; font-weight: 600;">${item.detail.name}</span>`;

        const btn = document.createElement('button');
        btn.textContent = '✕';
        btn.onclick = () => {
          state.loadedProteins.delete(id);
          upsertSelectedDyeList();
          drawHardware();
          calculateEfficiencies();
        };
        li.appendChild(btn);
        selectedDyesList.appendChild(li);
      });
    }

    function findArrayByKeyword(obj, keyword) {
      if (!obj) return null;
      for (const [key, value] of Object.entries(obj)) {
        if (key.toLowerCase().includes(keyword) && Array.isArray(value)) return value;
      }
      return null;
    }

    function normalizeSplitters(rawSplitters) {
      if (!Array.isArray(rawSplitters)) return [];
      return rawSplitters.map((s, i) => ({
        id: `splitter_${i}`, name: s.name || `Splitter ${i + 1}`, type: 'splitter_group',
        positions: { 1: s }
      }));
    }

    function normalizeMechanisms(rawData) {
      const stages = rawData?.stages || {};
      const splitters = rawData?.splitters || [];
      return {
        lightSources: Array.isArray(rawData?.light_sources) ? rawData.light_sources : (findArrayByKeyword(rawData, 'light_source') || []),
        excitation: Array.isArray(stages.excitation) ? stages.excitation : (findArrayByKeyword(rawData, 'excitation') || []),
        dichroic: Array.isArray(stages.dichroic) ? stages.dichroic : (findArrayByKeyword(rawData, 'dichroic') || []),
        emission: Array.isArray(stages.emission) ? stages.emission : (findArrayByKeyword(rawData, 'emission') || []),
        detectors: Array.isArray(rawData?.detectors) ? rawData.detectors : (findArrayByKeyword(rawData, 'detector') || []),
        splitters: normalizeSplitters(splitters),
      };
    }

    function isTunableMechanism(mechanism) {
      const type = String(mechanism?.type || mechanism?.component_type || '').toLowerCase();
      return type === 'tunable' || type === 'spectral_slider';
    }

    function renderControls() {
      controlContainer.innerHTML = '';
      const groups = [
        { key: 'lightSources', label: 'Light Sources / Lasers' },
        { key: 'excitation', label: 'Excitation Mechanisms' },
        { key: 'dichroic', label: 'Dichroic Mechanisms' },
        { key: 'emission', label: 'Emission Mechanisms' },
        { key: 'splitters', label: 'Splitters' },
        { key: 'detectors', label: 'Detectors' },
      ];

      groups.forEach(({ key, label }) => {
        const mechanisms = state.activeInstrument[key];
        if (!mechanisms || mechanisms.length === 0) return;

        const wrapper = document.createElement('div');
        wrapper.className = 'vm-mechanism-group';
        wrapper.style.marginBottom = '12px';

        const title = document.createElement('h3');
        title.className = 'vm-section-title';
        title.textContent = label;
        wrapper.appendChild(title);

        mechanisms.forEach((mech, mechIndex) => {
          if (isTunableMechanism(mech)) {
            wrapper.appendChild(createTunableControl(key, mech.name, mechIndex));
          } else {
            wrapper.appendChild(createSelectControl(key, mech, mechIndex));
          }
        });
        controlContainer.appendChild(wrapper);
      });
    }

    function createSelectControl(stageKey, mechanism, mechIndex) {
      const block = document.createElement('div');
      block.className = 'vm-field';

      const label = document.createElement('label');
      label.textContent = mechanism.name || `Mechanism ${mechIndex + 1}`;

      const select = document.createElement('select');
      select.dataset.stage = stageKey;
      select.dataset.mechanismName = mechanism.name;

      if (stageKey === 'splitters') {
        const pos = mechanism.positions?.[1] || {};
        const dText = pos.dichroic?.positions?.[1]?.cutoffs_nm ? `Di: ${pos.dichroic.positions[1].cutoffs_nm.join(', ')}` : 'Empty Dichroic';
        const p1Text = pos.path1?.positions?.[1]?.center_nm ? `P1: ${pos.path1.positions[1].center_nm}/${pos.path1.positions[1].width_nm}` : '';
        const p2Text = pos.path2?.positions?.[1]?.center_nm ? `P2: ${pos.path2.positions[1].center_nm}/${pos.path2.positions[1].width_nm}` : '';
        const opt = document.createElement('option');
        opt.value = JSON.stringify(pos);
        opt.textContent = [dText, p1Text, p2Text].filter(Boolean).join(' | ');
        select.appendChild(opt);
      } else {
        Object.entries(mechanism.positions || {}).forEach(([slot, comp]) => {
          const opt = document.createElement('option');
          opt.value = JSON.stringify(comp);
          let desc = comp.type || comp.component_type || 'Unknown';
          if (desc === 'empty') desc = 'Empty';
          else if (['bandpass', 'notch'].includes(desc) && comp.center_nm) desc = `${comp.center_nm}/${comp.width_nm} nm`;
          else if (desc === 'longpass' && comp.cut_on_nm) desc = `LP ${comp.cut_on_nm}`;
          else if (desc === 'shortpass' && comp.cut_off_nm) desc = `SP ${comp.cut_off_nm}`;
          else if (['dichroic', 'multiband_dichroic', 'polychroic'].includes(desc) && comp.cutoffs_nm) desc = `Di [${comp.cutoffs_nm.join(', ')}]`;
          else if (['laser', 'light_source'].includes(desc) && comp.wavelength_nm) desc = `${comp.name} (${comp.wavelength_nm} nm)`;
          else if (desc === 'detector') desc = comp.name || 'Camera';

          opt.textContent = `Slot ${slot}: ${desc}`;
          select.appendChild(opt);
        });
      }

      select.addEventListener('change', () => { drawHardware(); calculateEfficiencies(); });
      block.appendChild(label);
      block.appendChild(select);
      return block;
    }

    function createTunableControl(stageKey, name, mechIndex) {
      const block = document.createElement('div');
      block.className = 'vm-field';

      const titleLabel = document.createElement('label');
      titleLabel.textContent = name || `Tunable Filter ${mechIndex + 1}`;
      block.appendChild(titleLabel);

      const tWrap = document.createElement('div');
      tWrap.className = 'tunable-control';
      tWrap.dataset.stage = stageKey;
      tWrap.dataset.mechanismName = name;

      const valLabel = document.createElement('div');
      valLabel.className = 'tunable-range-label';

      const sRow = document.createElement('div');
      sRow.className = 'slider-row';

      const minIn = document.createElement('input');
      minIn.type = 'range'; minIn.min = 400; minIn.max = 800; minIn.value = 500;
      const maxIn = document.createElement('input');
      maxIn.type = 'range'; maxIn.min = 400; maxIn.max = 800; maxIn.value = 550;

      function updateVal() {
        if (Number(minIn.value) > Number(maxIn.value)) minIn.value = maxIn.value;
        valLabel.textContent = `Active Range: ${minIn.value} nm — ${maxIn.value} nm`;
        tWrap.dataset.value = JSON.stringify({ component_type: 'tunable', band_start_nm: minIn.value, band_end_nm: maxIn.value });
        drawHardware();
        calculateEfficiencies();
      }

      minIn.addEventListener('input', updateVal);
      maxIn.addEventListener('input', updateVal);

      sRow.appendChild(minIn);
      sRow.appendChild(maxIn);
      tWrap.appendChild(valLabel);
      tWrap.appendChild(sRow);

      block.appendChild(tWrap);
      updateVal();
      return block;
    }

    function selectedPositions() {
      const results = [];
      const selects = Array.from(controlContainer.querySelectorAll('select'));
      selects.forEach(sel => {
        if (!sel.value) return;
        try {
          const val = JSON.parse(sel.value);
          if (sel.dataset.stage === 'splitters') {
            if (val.dichroic?.positions?.[1]) results.push({ stage: 'splitterDichroic', name: 'Splitter Dichroic', position: val.dichroic.positions[1] });
            if (val.path1?.positions?.[1]) results.push({ stage: 'splitterPath1', name: 'Path 1 Filter', position: val.path1.positions[1] });
            if (val.path2?.positions?.[1]) results.push({ stage: 'splitterPath2', name: 'Path 2 Filter', position: val.path2.positions[1] });
          } else {
            results.push({ stage: sel.dataset.stage, name: sel.dataset.mechanismName, position: val });
          }
        } catch(e) {}
      });

      const tunables = Array.from(controlContainer.querySelectorAll('.tunable-control'));
      tunables.forEach(tun => {
        if (!tun.dataset.value) return;
        try {
          results.push({ stage: tun.dataset.stage, name: tun.dataset.mechanismName, position: JSON.parse(tun.dataset.value) });
        } catch(e) {}
      });

      return results;
    }

    function drawHardware() {
      if (!chartInstance) return;
      const activePositions = selectedPositions();
      const hardwareDatasets = activePositions.flatMap(p => hardwareDatasetFromPosition(p.stage, p.name, p.position));

      const proteinDatasets = [];
      state.loadedProteins.forEach((item) => {
        const spectra = extractSpectra(item.detail);
        const color = wavelengthToColorHex(item.detail.emMax || 520);
        if (spectra.excitation.length) {
          proteinDatasets.push({
            label: `${item.detail.name} (Ex)`,
            data: spectra.excitation,
            borderColor: color,
            borderDash: [5, 5],
            borderWidth: 2,
            tension: 0.3,
            pointRadius: 0,
            fill: false,
            parsing: false
          });
        }
        if (spectra.emission.length) {
          proteinDatasets.push({
            label: `${item.detail.name} (Em)`,
            data: spectra.emission,
            borderColor: color,
            backgroundColor: color.replace(')', ', 0.15)').replace('rgb', 'rgba'),
            borderWidth: 2,
            tension: 0.3,
            pointRadius: 0,
            fill: true,
            parsing: false
          });
        }
      });

      chartInstance.data.datasets = [...hardwareDatasets, ...proteinDatasets];
      chartInstance.update();
      updatePathSummary();
    }

    function hardwareDatasetFromPosition(stage, mechanismName, position) {
      if (stage === 'detectors' || position.component_type === 'detector' || position.type === 'empty') return [];

      const componentType = String(position.type || position.component_type || '').toLowerCase();

      if (componentType === 'tunable' && position.band_start_nm) {
        return [createBandDataset(`${mechanismName} (Tunable)`, Number(position.band_start_nm), Number(position.band_end_nm), '#3b82f6')];
      }

      if (['laser', 'light_source'].includes(componentType)) {
        const wl = Number(position.wavelength_nm);
        if (!Number.isNaN(wl)) return [createLaserSpikeDataset(`${position.name || 'Laser'}`, wl)];
        return [createTunableDataset(`${position.name || 'White Light Laser'}`)];
      }

      if (['bandpass', 'notch'].includes(componentType) && position.center_nm) {
        const center = Number(position.center_nm);
        const width = Number(position.width_nm);
        const color = stage.includes('emission') || stage.includes('splitterPath') ? 'rgba(34, 197, 94, 0.2)' : 'rgba(59, 130, 246, 0.2)';
        const border = stage.includes('emission') || stage.includes('splitterPath') ? '#16a34a' : '#2563eb';
        return [createBandDataset(`${mechanismName} ${center}/${width}`, center - width/2, center + width/2, border, color)];
      }

      if (['dichroic', 'multiband_dichroic', 'polychroic'].includes(componentType) && position.cutoffs_nm) {
        return position.cutoffs_nm.map(cutoff => createStepDataset(`Dichroic Cutoff ${cutoff}`, Number(cutoff), stage === 'splitterDichroic' ? '#a855f7' : '#94a3b8'));
      }

      if (componentType === 'longpass' && position.cut_on_nm) return [createStepDataset(`LP ${position.cut_on_nm}`, Number(position.cut_on_nm), '#f59e0b')];
      if (componentType === 'shortpass' && position.cut_off_nm) return [createStepDataset(`SP ${position.cut_off_nm}`, Number(position.cut_off_nm), '#f59e0b', true)];

      return [];
    }

    function createBandDataset(label, start, end, borderColor, bgColor = 'rgba(203, 213, 225, 0.3)') {
      return {
        label,
        data: [{x: start, y: 0}, {x: start, y: 100}, {x: end, y: 100}, {x: end, y: 0}],
        borderColor,
        backgroundColor: bgColor,
        borderWidth: 2,
        fill: true,
        stepped: 'middle',
        pointRadius: 0
      };
    }

    function createStepDataset(label, cutoff, color, reverse = false) {
      const before = reverse ? 100 : 0;
      const after = reverse ? 0 : 100;
      return {
        label,
        data: [{x: 350, y: before}, {x: cutoff, y: before}, {x: cutoff, y: after}, {x: 800, y: after}],
        borderColor: color,
        borderDash: [4, 4],
        borderWidth: 2,
        fill: false,
        stepped: 'after',
        pointRadius: 0
      };
    }

    function createLaserSpikeDataset(label, wl) {
      return {
        label,
        data: [{x: wl, y: 0}, {x: wl, y: 100}],
        borderColor: '#0f172a',
        borderWidth: 2,
        fill: false,
        pointRadius: 0
      };
    }

    function createTunableDataset(label) {
      return {
        label: `${label} (Broad Spectrum)`,
        data: [{x: 400, y: 0}, {x: 400, y: 100}, {x: 800, y: 100}, {x: 800, y: 0}],
        borderColor: '#94a3b8',
        backgroundColor: 'rgba(226, 232, 240, 0.4)',
        borderWidth: 1,
        borderDash: [2, 2],
        fill: true,
        stepped: 'middle',
        pointRadius: 0
      };
    }

    function formatFilterText(stageData) {
      if (!stageData) return null;
      let bandText = '';
      const tunables = Array.from(controlContainer.querySelectorAll('.tunable-control'));
      const activeTunable = tunables.find(t => t.dataset.stage === stageData.stage);

      if (activeTunable && activeTunable.dataset.value) {
        const v = JSON.parse(activeTunable.dataset.value);
        bandText = `${v.band_start_nm}-${v.band_end_nm} nm`;
      } else {
        const position = stageData.position;
        const ctype = String(position.type || position.component_type || '').toLowerCase();
        if (['bandpass', 'notch'].includes(ctype) && position.center_nm) bandText = `${position.center_nm}/${position.width_nm} nm`;
        else if (ctype === 'longpass') bandText = `LP ${position.cut_on_nm}`;
        else if (ctype === 'shortpass') bandText = `SP ${position.cut_off_nm}`;
        else if (['dichroic', 'multiband_dichroic'].includes(ctype)) bandText = `Di [${position.cutoffs_nm?.join(', ')}]`;
        else bandText = ctype;
      }

      if (bandText && bandText !== 'empty') {
        const label = stageData.position.manufacturer ? `${stageData.position.manufacturer} ${stageData.position.product_code || ''}`.trim() : '';
        return `<strong>${bandText}</strong>${label ? ` <span class="vm-status" style="margin:0">(${label})</span>` : ''}`;
      }
      return null;
    }

    function updatePathSummary() {
      const selected = selectedPositions();
      const path1 = selected.find((entry) => String(entry.stage).startsWith('splitterPath1'));
      const path2 = selected.find((entry) => String(entry.stage).startsWith('splitterPath2'));
      const em1Text = formatFilterText(selected.find(e => e.stage === 'emission'));

      if (path1 || path2) {
        pathSummary.innerHTML = `<strong>Splitter Active</strong> &nbsp;&rarr;&nbsp; Path 1: ${formatFilterText(path1) || '—'} &nbsp;|&nbsp; Path 2: ${formatFilterText(path2) || '—'}`;
      } else {
        pathSummary.innerHTML = `<strong>Active Emission:</strong> &nbsp; ${em1Text || '—'}`;
      }
    }

    function integrateArea(curve, minWl, maxWl) {
      let area = 0;
      for (let i = 0; i < curve.length - 1; i++) {
        const p1 = curve[i];
        const p2 = curve[i+1];
        if (p2.x <= minWl || p1.x >= maxWl) continue;
        const overlapStartX = Math.max(p1.x, minWl);
        const overlapEndX = Math.min(p2.x, maxWl);
        const fraction = (overlapEndX - overlapStartX) / (p2.x - p1.x);
        const avgY = (p1.y + p2.y) / 2;
        area += fraction * (p2.x - p1.x) * avgY;
      }
      return area;
    }

    function getTotalArea(curve) {
      if (!curve || curve.length < 2) return 1;
      return integrateArea(curve, 0, 9999);
    }

    function calculateEfficiencies() {
      signalSimulator.innerHTML = '';
      if (state.loadedProteins.size === 0) {
        signalSimulator.innerHTML = '<li class="vm-simulator-item" style="color:var(--muted)">Add a fluorophore to begin.</li>';
        return;
      }

      const activePositions = selectedPositions();
      const activeLights = activePositions.filter(p => p.stage === 'lightSources');
      const activeEms = activePositions.filter(p => p.stage === 'emission' || String(p.stage).startsWith('splitterPath'));

      state.loadedProteins.forEach((item) => {
        const spectra = extractSpectra(item.detail);
        let exEff = 0;

        activeLights.forEach(light => {
          const type = String(light.position.type || light.position.component_type || '').toLowerCase();
          if (type.includes('laser') && light.position.wavelength_nm) {
            const wl = Number(light.position.wavelength_nm);
            const pt = spectra.excitation.find(p => Math.abs(p.x - wl) <= 2);
            if (pt && pt.y > exEff) exEff = pt.y;
          }
        });

        let emEff = 0;
        activeEms.forEach(em => {
          const ctype = String(em.position.type || em.position.component_type || '').toLowerCase();
          let start = 0, end = 0;
          if (ctype === 'tunable') {
            start = Number(em.position.band_start_nm); end = Number(em.position.band_end_nm);
          } else if (['bandpass', 'notch'].includes(ctype) && em.position.center_nm) {
            start = Number(em.position.center_nm) - Number(em.position.width_nm)/2;
            end = Number(em.position.center_nm) + Number(em.position.width_nm)/2;
          } else if (ctype === 'longpass') {
            start = Number(em.position.cut_on_nm); end = 1000;
          } else if (ctype === 'shortpass') {
            start = 0; end = Number(em.position.cut_off_nm);
          }
          if (start > 0 || end > 0) {
            const area = integrateArea(spectra.emission, start, end);
            const total = getTotalArea(spectra.emission);
            const fraction = (area / total) * 100;
            if (fraction > emEff) emEff = fraction;
          }
        });

        if (activeLights.length === 0) exEff = 100;
        if (activeEms.length === 0) emEff = 100;

        const totalEff = (exEff / 100) * (emEff / 100) * 100;

        const li = document.createElement('li');
        li.className = 'vm-simulator-item';
        li.innerHTML = `<strong>${item.detail.name}</strong> &nbsp;&rarr;&nbsp; Ex: ${exEff.toFixed(1)}% | Em: ${emEff.toFixed(1)}% | <strong>Total: ${totalEff.toFixed(1)}%</strong>`;
        signalSimulator.appendChild(li);
      });
    }

    function wavelengthToColorHex(wl) {
      let r = 0, g = 0, b = 0;
      if (wl >= 380 && wl < 440) { r = -(wl - 440) / (440 - 380); b = 1; }
      else if (wl >= 440 && wl < 490) { g = (wl - 440) / (490 - 440); b = 1; }
      else if (wl >= 490 && wl < 510) { g = 1; b = -(wl - 510) / (510 - 490); }
      else if (wl >= 510 && wl < 580) { r = (wl - 510) / (580 - 510); g = 1; }
      else if (wl >= 580 && wl < 645) { r = 1; g = -(wl - 645) / (645 - 580); }
      else if (wl >= 645 && wl <= 780) { r = 1; }
      const factor = (wl >= 380 && wl < 420) ? 0.3 + 0.7*(wl - 380)/(420 - 380) : (wl > 700 && wl <= 780) ? 0.3 + 0.7*(780 - wl)/(780 - 700) : 1;
      const toHex = c => Math.round(c * factor * 255).toString(16).padStart(2, '0');
      return `#${toHex(r)}${toHex(g)}${toHex(b)}`;
    }

    function debounce(func, wait) {
      let timeout;
      return function(...args) {
        clearTimeout(timeout);
        timeout = setTimeout(() => func.apply(this, args), wait);
      };
    }

    window.onload = init;
  })();
</script>
