## QC Metrics: Latest Measurements

{% set laser_metrics = {} %}
{% set other_metrics = {} %}
{% for k, v in latest_metrics.items() %}
  {% if k.startswith('laser.') %}
    {% set _ = laser_metrics.update({k: v}) %}
  {% elif not k.startswith('psf.') and not k.startswith('chromatic_shift.') %}
    {% set _ = other_metrics.update({k: v}) %}
  {% endif %}
{% endfor %}

### 🔦 Laser Performance

{% if laser_metrics %}
<div class="grid cards" markdown>

{% for m_id, m_val in laser_metrics.items() %}
-   **{{ metric_names.get(m_id, m_id) }}**

    ---

    <span style="font-size: 1.5em; font-weight: bold; color: var(--md-primary-fg-color);">{{ m_val }}</span><br>
    <span class="aic-muted" style="font-size: 0.8em;"><code>{{ m_id }}</code></span>

{% endfor %}

</div>
{% else %}
> *No laser performance metrics recorded recently.*
{% endif %}

### 🔬 Optical Resolution (PSF & Alignment)

{% if hw.objectives %}
  {% set obj_with_data = [] %}
  {% set obj_without_data = [] %}

  {# 1. Sort objectives into "has data" and "no data" buckets #}
  {% for obj in hw.objectives %}
    {% if obj.id %}
      {% set obj_metrics = {} %}
      {% for k, v in latest_metrics.items() %}
        {% if k.startswith('psf.' ~ obj.id ~ '.') or k.startswith('chromatic_shift.' ~ obj.id ~ '.') %}
          {% set _ = obj_metrics.update({k: v}) %}
        {% endif %}
      {% endfor %}

      {% if obj_metrics %}
        {% set _ = obj_with_data.append((obj, obj_metrics)) %}
      {% else %}
        {% set _ = obj_without_data.append(obj) %}
      {% endif %}
    {% endif %}
  {% endfor %}

  {# 2. Display objectives with data #}
  {% if obj_with_data %}
    {% for obj, obj_metrics in obj_with_data %}

#### **{{ obj.display_label }}** <small class="aic-muted">(`{{ obj.id }}`)</small>

<div class="grid cards" markdown>

{% for m_id, m_val in obj_metrics.items() %}
-   **{{ metric_names.get(m_id, m_id.split('.')[-1] | replace('_', ' ') | title ) }}**

    ---

    <span style="font-size: 1.5em; font-weight: bold; color: var(--md-primary-fg-color);">{{ m_val }}</span><br>
    <span class="aic-muted" style="font-size: 0.75em;"><code>{{ m_id }}</code></span>

{% endfor %}

</div>

    {% endfor %}
  {% else %}
> *No recent PSF or chromatic shift metrics available for any objectives.*
  {% endif %}

  {# 3. Collapse objectives without data into an expandable block #}
  {% if obj_without_data %}
??? info "Objectives without recent data"
    {% for obj in obj_without_data %}
    - **{{ obj.display_label }}** <small class="aic-muted">(`{{ obj.id }}`)</small>
    {% endfor %}
  {% endif %}

{% else %}
> *No objectives defined for this instrument.*
{% endif %}

{% if other_metrics %}
### ⚙️ Environment & Stage Performance

<div class="grid cards" markdown>

{% for m_id, m_val in other_metrics.items() %}
-   **{{ metric_names.get(m_id, m_id) }}**

