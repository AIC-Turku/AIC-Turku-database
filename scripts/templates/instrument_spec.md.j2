---
title: instrument spec
hide:
  - toc  
---


{% macro render_spec_card(item) -%}
- **{% if item.url %}[{{ item.display_label }}]({{ item.url }}){:target="_blank"}{% else %}{{ item.display_label }}{% endif %}**{% if item.display_subtitle %}
  <br><small class="aic-muted">{{ item.display_subtitle }}</small>{% endif %}
  {% for line in item.spec_lines %}<br>{{ line }}{% endfor %}
{%- endmacro %}

{%- set dto = instrument.dto -%}
{%- set hw = dto.hardware -%}
{%- set identity = dto.identity if dto.identity else {} -%}
{%- set optical_path = hw.optical_path if hw.optical_path else {} -%}
{%- set route_graphs = optical_path.light_paths or [] -%}
{%- set hardware_inventory = optical_path.hardware_inventory or [] -%}
{%- set hardware_index_map = optical_path.hardware_index_map if optical_path.hardware_index_map else {} -%}

# {% if identity.url %}[{{ identity.display_name }}]({{ identity.url }}){:target="_blank"}{% else %}{{ identity.display_name }}{% endif %}

!!! warning "Work in progress"
    This dashboard is a work in progress. Please independently verify critical information, as not all features are working yet.


{% set status_class = 'success' if dto.status.color == 'green' else 'warning' if dto.status.color == 'yellow' else 'danger' %}
!!! {{ status_class }} "Current Status: {{ dto.status.badge }}"
    {{ dto.status.reason }}
    
    [📊 View QC & Maintenance History](history.md){ .md-button .md-button--primary }
    [🔬 Open Virtual Microscope](../../virtual_microscope.md?scope={{ identity.id }}){ .md-button }

<div class="aic-hero">
  <div class="aic-hero__media">
    <img src="../../assets/images/{{ identity.image_filename }}" alt="{{ identity.display_name }}"
         onerror="this.onerror=null; this.src='../../assets/images/placeholder.svg';" />
  </div>

  <div class="aic-hero__facts">
    <div class="aic-facts">
      <div class="aic-fact">
        <div class="aic-muted">Manufacturer</div>
        <div>{{ dto.identity.manufacturer or '—' }}</div>
      </div>
      <div class="aic-fact">
        <div class="aic-muted">Model</div>
        <div>{{ dto.identity.model or '—' }}</div>
      </div>
      <div class="aic-fact">
        <div class="aic-muted">Stand</div>
        <div>{{ dto.identity.stand_orientation.display_label or '—' }}</div>
      </div>
      <div class="aic-fact">
        <div class="aic-muted">Eyepieces</div>
        <div>{{ dto.identity.ocular_availability.display_label or '—' }}</div>
      </div>
      <div class="aic-fact">
        <div class="aic-muted">Location</div>
        <div>{{ dto.identity.location or '—' }}</div>
      </div>
      <div class="aic-fact">
        <div class="aic-muted">Purchased</div>
        <div>{{ dto.identity.year_of_purchase or '—' }}</div>
      </div>
      <div class="aic-fact">
        <div class="aic-muted">Funding</div>
        <div>{{ dto.identity.funding or '—' }}</div>
      </div>
    </div>
  </div>
</div>



<div class="aic-section" style="margin-top: 20px;">
  <div class="aic-section__title">Capabilities</div>
  <div class="aic-muted">Imaging modes</div>
  <div class="aic-chiprow">{% for mod in dto.capabilities.imaging_modes %}<span class="aic-chip">{{ mod.display_label }}</span>{% else %}<span class="aic-muted">—</span>{% endfor %}</div>
  <div class="aic-muted">Contrast methods</div>
  <div class="aic-chiprow">{% for mod in dto.capabilities.contrast_methods %}<span class="aic-chip">{{ mod.display_label }}</span>{% else %}<span class="aic-muted">—</span>{% endfor %}</div>
  <div class="aic-muted">Readouts</div>
  <div class="aic-chiprow">{% for mod in dto.capabilities.readouts %}<span class="aic-chip">{{ mod.display_label }}</span>{% else %}<span class="aic-muted">—</span>{% endfor %}</div>
  <div class="aic-muted">Workflows</div>
  <div class="aic-chiprow">{% for mod in dto.capabilities.workflows %}<span class="aic-chip">{{ mod.display_label }}</span>{% else %}<span class="aic-muted">—</span>{% endfor %}</div>
  <div class="aic-muted">Assay operations</div>
  <div class="aic-chiprow">{% for mod in dto.capabilities.assay_operations %}<span class="aic-chip">{{ mod.display_label }}</span>{% else %}<span class="aic-muted">—</span>{% endfor %}</div>
  <div class="aic-muted">Non-optical capabilities</div>
  <div class="aic-chiprow">{% for mod in dto.capabilities.non_optical %}<span class="aic-chip">{{ mod.display_label }}</span>{% else %}<span class="aic-muted">—</span>{% endfor %}</div>
  <div class="aic-muted" style="margin-top:8px;">Legacy modalities (compatibility)</div>
  <div class="aic-chiprow">
    {% for mod in dto.modalities %}
      <span class="aic-chip">{{ mod.display_label }}</span>
    {% else %}
      <span class="aic-muted">—</span>
    {% endfor %}
  </div>
</div>

{% set route_contract = dto.hardware.optical_path.authoritative_route_contract if dto.hardware.optical_path and dto.hardware.optical_path.authoritative_route_contract else {} %}
{% set route_rows = route_contract.routes if route_contract and route_contract.routes else [] %}
{% if route_rows %}
<div class="aic-section">
  <div class="aic-section__title">Optical routes and route-level readouts</div>
  {% for route in route_rows %}
    {% set route_identity = route.route_identity if route.route_identity else {} %}
    <div style="margin-bottom: 10px;">
      <div><strong>Route:</strong> {{ route.display_label or route.id }}</div>
      <div class="aic-muted"><strong>Route type:</strong> {{ route_identity.route_type_label or route_identity.route_type or route.illumination_mode or '—' }}</div>
      <div class="aic-chiprow">
        {% for ro in (route_identity.readouts or []) %}
          <span class="aic-chip">{{ ro.display_label or ro.id }}</span>
        {% else %}
          <span class="aic-muted">Readouts: —</span>
        {% endfor %}
      </div>
    </div>
  {% endfor %}
</div>
{% endif %}

{% if dto.modules %}
<div class="aic-section">
  <div class="aic-section__title">Modules</div>
  <div class="aic-chiprow">
    {% for m in dto.modules %}
      {% if m.url %}
        <a class="aic-chip" href="{{ m.url }}" target="_blank">{{ m.display_label }}</a>
      {% else %}
        <span class="aic-chip">{{ m.display_label }}</span>
      {% endif %}
    {% endfor %}
  </div>
</div>
{% endif %}

