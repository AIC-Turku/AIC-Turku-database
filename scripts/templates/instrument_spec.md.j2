{% macro render_spec_card(item) -%}
- **{% if item.url %}[{{ item.display_label }}]({{ item.url }}){:target="_blank"}{% else %}{{ item.display_label }}{% endif %}**
  {% if item.display_subtitle %}<br><small class="aic-muted">{{ item.display_subtitle }}</small>{% endif %}
  {% for line in item.spec_lines %}<br>{{ line }}{% endfor %}
{%- endmacro %}

{% set dto = instrument.dto %}
{% set hw = dto.hardware %}
{% set identity = dto.identity if dto.identity else {} %}
{% set canonical = instrument.canonical if instrument.canonical else {} %}
{% set policy = canonical.policy if canonical.policy else {} %}

# {% if identity.url %}[{{ identity.display_name }}]({{ identity.url }}){:target="_blank"}{% else %}{{ identity.display_name }}{% endif %}

{% set status_class = 'success' if instrument.status.color == 'green' else 'warning' if instrument.status.color == 'yellow' else 'danger' %}
!!! {{ status_class }} "Current Status: {{ instrument.status.badge }}"
    {{ instrument.status.reason }}
    
    [📊 View QC & Maintenance History](history.md){ .md-button .md-button--primary }
    [🔬 Open Virtual Microscope](../../virtual_microscope.md?scope={{ identity.id }}){ .md-button }

<div class="aic-hero">
  <div class="aic-hero__media">
    <img src="../../assets/images/{{ identity.image_filename }}" alt="{{ identity.display_name }}"
         onerror="this.onerror=null; this.src='../../assets/images/placeholder.svg';" />
  </div>

  <div class="aic-hero__facts">
    <div class="aic-facts">
      <div class="aic-fact">
        <div class="aic-muted">Manufacturer</div>
        <div>{{ dto.identity.manufacturer or '—' }}</div>
      </div>
      <div class="aic-fact">
        <div class="aic-muted">Model</div>
        <div>{{ dto.identity.model or '—' }}</div>
      </div>
      <div class="aic-fact">
        <div class="aic-muted">Stand</div>
        <div>{{ dto.identity.stand_orientation.display_label or '—' }}</div>
      </div>
      <div class="aic-fact">
        <div class="aic-muted">Eyepieces</div>
        <div>{{ dto.identity.ocular_availability.display_label or '—' }}</div>
      </div>
      <div class="aic-fact">
        <div class="aic-muted">Location</div>
        <div>{{ dto.identity.location or '—' }}</div>
      </div>
      <div class="aic-fact">
        <div class="aic-muted">Purchased</div>
        <div>{{ dto.identity.year_of_purchase or '—' }}</div>
      </div>
      <div class="aic-fact">
        <div class="aic-muted">Funding</div>
        <div>{{ dto.identity.funding or '—' }}</div>
      </div>
    </div>
  </div>
</div>

{% if instrument.notes %}
## Capabilities

{% if instrument.notes.type %}
- **Type:** {{ instrument.notes.type }}
{% endif %}

{% if instrument.notes.imaging_modes %}
- **Imaging modes:** {{ instrument.notes.imaging_modes | join(', ') }}
{% endif %}

{% if instrument.notes.filters %}
- **Filters:**
{% for f in instrument.notes.filters %}
  - {{ f }}
{% endfor %}
{% endif %}

{% if instrument.notes.additional_hardware %}
- **Additional hardware:**
{% for h in instrument.notes.additional_hardware %}
  - {{ h }}
{% endfor %}
{% endif %}

{% if instrument.notes.raw %}
- **Notes:** {{ instrument.notes.raw }} <small class="aic-muted">(legacy notes fallback)</small>
{% endif %}
{% endif %}

<div class="aic-section" style="margin-top: 20px;">
  <div class="aic-section__title">Modalities</div>
  <div class="aic-chiprow">
    {% for mod in dto.modalities %}
      <span class="aic-chip">{{ mod.display_label }}</span>
    {% else %}
      <span class="aic-muted">—</span>
    {% endfor %}
  </div>
</div>

{% if dto.modules %}
<div class="aic-section">
  <div class="aic-section__title">Modules</div>
  <div class="aic-chiprow">
    {% for m in dto.modules %}
      {% if m.url %}
        <a href="{{ m.url }}" target="_blank" class="aic-chip aic-chip--muted" title="{{ m.display_subtitle }}">{{ m.display_label }} ↗</a>
      {% else %}
        <span class="aic-chip aic-chip--muted" title="{{ m.display_subtitle }}">{{ m.display_label }}</span>
      {% endif %}
    {% endfor %}
  </div>
</div>
{% endif %}

<br>


