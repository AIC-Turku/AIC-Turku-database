{% macro objective_label(obj) -%}
{%- set mag = obj.magnification -%}
{%- set immersion = (obj.immersion | capitalize) if obj.immersion else '' -%}
{%- if mag is number -%}
{{ mag | int }}x{% if immersion %} {{ immersion }}{% endif %}
{%- elif mag is string and mag | trim -%}
{{ mag | trim }}x{% if immersion %} {{ immersion }}{% endif %}
{%- else -%}
—x{% if immersion %} {{ immersion }}{% endif %}
{%- endif -%}
{%- endmacro %}

{% macro bool_label(value) -%}
{%- if value is sameas true -%}Yes{%- elif value is sameas false -%}No{%- else -%}—{%- endif -%}
{%- endmacro %}

{% macro pretty_id(value) -%}
{%- if value -%}{{ value | replace('_', ' ') | title }}{%- else -%}—{%- endif -%}
{%- endmacro %}

{% macro render_optical_component(component) -%}
{%- if component and component.type and component.type != 'empty' -%}
{%- set ctype = component.type | lower -%}
**{{ component.name or pretty_id(component.type) }}**
{%- if ctype in ['bandpass', 'notch'] and component.center_nm is not none and component.width_nm is not none -%}
<br><small>Center: {{ component.center_nm }}nm, Width: {{ component.width_nm }}nm</small>
{%- elif ctype == 'longpass' and component.cut_on_nm is not none -%}
<br><small>Cut-on: {{ component.cut_on_nm }}nm</small>
{%- elif ctype == 'shortpass' and component.cut_off_nm is not none -%}
<br><small>Cut-off: {{ component.cut_off_nm }}nm</small>
{%- elif ctype in ['dichroic', 'multiband'] and component.cutoffs_nm -%}
<br><small>Cutoffs: {{ component.cutoffs_nm | join(', ') }} nm</small>
{%- endif -%}
{%- if component.manufacturer or component.product_code -%}
<br><small class="aic-muted">Ref: {{ component.manufacturer or '' }} {{ component.product_code or '' }}</small>
{%- endif -%}
{%- else -%}
<span class="aic-muted"><em>Empty</em></span>
{%- endif -%}
{%- endmacro %}

