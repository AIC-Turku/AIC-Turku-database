{% macro objective_label(obj) -%}
{%- set mag = obj.magnification -%}
{%- set immersion = (obj.immersion | capitalize) if obj.immersion else '' -%}
{%- if mag is number -%}
{{ mag | int }}x{% if immersion %} {{ immersion }}{% endif %}
{%- elif mag is string and mag | trim -%}
{{ mag | trim }}x{% if immersion %} {{ immersion }}{% endif %}
{%- else -%}
—x{% if immersion %} {{ immersion }}{% endif %}
{%- endif -%}
{%- endmacro %}

{% macro bool_label(value) -%}
{%- if value is sameas true -%}Yes
{%- elif value is sameas false -%}No
{%- else -%}—
{%- endif -%}
{%- endmacro %}

{% macro pretty_id(value) -%}
{%- if value -%}{{ value | replace('_', ' ') | title }}
{%- else -%}—
{%- endif -%}
{%- endmacro %}

{% macro ext_link(label, url=None) -%}
{%- if label -%}
  {%- if url -%}[{{ label }}]({{ url }}){:target="_blank"}
  {%- else -%}{{ label }}
  {%- endif -%}
{%- else -%}—
{%- endif -%}
{%- endmacro %}

{% macro muted_value(value, code=false) -%}
{%- if value is not none and value != '' and value != [] -%}
  {%- if code -%}`{{ value }}`
  {%- else -%}{{ value }}
  {%- endif -%}
{%- else -%}<span class="aic-muted">—</span>
{%- endif -%}
{%- endmacro %}

{% macro chip(text, muted=false) -%}
{%- if text -%}
<span class="aic-chip{% if muted %} aic-chip--muted{% endif %}">{{ text }}</span>
{%- endif -%}
{%- endmacro %}

{% macro chips(values, muted=false) -%}
{%- if values -%}
<div class="aic-chiprow">
  {%- for item in values %}
    {{ chip(item, muted=muted) }}
  {%- endfor %}
</div>
{%- else -%}
<span class="aic-muted">—</span>
{%- endif -%}
{%- endmacro %}

{% macro kv(label, value, code=false) -%}
{%- if value is not none and value != '' and value != [] -%}
<div><span class="aic-muted">{{ label }}:</span> {% if code %}`{{ value }}`{% else %}{{ value }}{% endif %}</div>
{%- endif -%}
{%- endmacro %}

{% macro render_notes(value) -%}
{%- if value -%}<small class="aic-muted">{{ value }}</small>{%- endif -%}
{%- endmacro %}

{% macro section_empty(text) -%}
> *{{ text }}*
{%- endmacro %}

